---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE, THREE_PROMISES } from "../../data/site";
---

<BaseLayout
  title="私たちの考え"
  description="湘南桑田歯科が大切にしている3つの約束と治療方針をご紹介します。"
>
  <PageHero
    title="私たちの考え"
    subtitle="治療の前に、当院が大切にしていることをお伝えします"
    image="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=1400&q=80"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "私たちの考え" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <p class="eyebrow">大切にしていること</p>
      <h2 class="section-title">3つの約束</h2>
      <p class="section-lead">
        {SITE.name}では、患者さんが安心して相談できることを最優先に考えています。
      </p>

      <div class="promise-stack">
        {THREE_PROMISES.map((promise, index) => (
          <article class="promise-row">
            <div class="promise-mark">{String(index + 1).padStart(2, "0")}</div>
            <div class="promise-body card">
              <p class="promise-kicker">約束 0{index + 1}</p>
              <h3>{promise.title}</h3>
              <p>{promise.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-alt">
    <div class="container-narrow policy-grid">
      <article class="policy-card card">
        <h3>説明を先に、治療はそのあとに</h3>
        <p>
          いまのお口の状態、考えられる治療方法、通院の見通しを、できるだけわかりやすい言葉でお伝えします。
          すぐに決めなくても問題ありません。まずは理解していただくことを大切にしています。
        </p>
      </article>
      <article class="policy-card card">
        <h3>患者さんの気持ちを起点に考える</h3>
        <p>
          「怖い」「しみる」「怒られそう」「久しぶりで気まずい」。そうした気持ちは、治療方針と同じくらい大切な情報です。
          不安を含めてお話しいただけるよう、圧をかけない診療を心がけています。
        </p>
      </article>
      <article class="policy-card card">
        <h3>予防まで含めて診る</h3>
        <p>
          治療したら終わりではなく、再発を防ぐところまで含めてご案内します。
          虫歯や歯周病の治療後も、定期検診やクリーニングで長く歯を守る方針です。
        </p>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow split-grid">
      <div>
        <p class="eyebrow">診療への考え方</p>
        <h2 class="section-title-left">治療は、内容を理解してから進めるものだと考えています。</h2>
        <p>
          歯科治療は、痛みや費用への不安がつきものです。
          そのため当院では、状態の確認だけでなく、患者さんが何を一番気にしているかを最初にうかがいます。
        </p>
        <p>
          必要以上に削らないこと、押し付けないこと、説明を省かないこと。
          その積み重ねが、通いやすさにつながると考えています。
        </p>
      </div>
      <div class="split-panel card">
        <p class="panel-title">診療で大切にしていること</p>
        <ul class="panel-list">
          <li>応急処置が必要な場合は、まず痛みを和らげる</li>
          <li>治療の選択肢は複数提示する</li>
          <li>費用や通院回数も先に見通しを共有する</li>
          <li>迷っている段階では、相談だけでも受ける</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding bg-section">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">初診のご案内</p>
        <h2>初めての方は、こちらもご覧ください。</h2>
        <p>初診の流れや持ち物を先に確認しておくと、来院の不安を減らしやすくなります。</p>
      </div>
      <a href="/first-visit/" class="btn-primary">初めての方へ</a>
    </div>
  </section>

  <SectionCTA />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: 1.9rem;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .section-lead {
    color: var(--color-text-light);
    line-height: 1.85;
    max-width: 680px;
    margin-bottom: 2rem;
  }
  .promise-stack {
    display: grid;
    gap: 1.25rem;
  }
  .promise-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.25rem;
    align-items: center;
  }
  .promise-mark {
    font-size: clamp(3.2rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--color-primary-light);
    line-height: 1;
    text-align: center;
  }
  .promise-body {
    padding: 2rem;
  }
  .promise-kicker {
    letter-spacing: 0.18em;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .promise-body h3,
  .policy-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }
  .promise-body p,
  .policy-card p,
  .split-grid p {
    line-height: 1.9;
    color: var(--color-text-light);
  }
  .policy-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .policy-card {
    padding: 2rem;
  }
  .split-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }
  .split-panel {
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(43, 107, 138, 0.06), transparent),
      var(--color-bg);
  }
  .panel-title {
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .panel-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }
  .panel-list li {
    padding-left: 1.4rem;
    position: relative;
    line-height: 1.8;
    color: var(--color-text);
  }
  .panel-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent-light);
    box-shadow: inset 0 0 0 2px var(--color-accent);
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .policy-grid,
    .split-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
    .promise-row {
      grid-template-columns: 1fr;
    }
    .promise-mark {
      text-align: left;
    }
  }
</style>
