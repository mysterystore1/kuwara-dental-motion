---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE, THREE_PROMISES } from "../../data/site";
import { VISUALS } from "../../data/visualAssets";
---

<BaseLayout
  title="私たちの考え"
  description="辻堂がじゅまる歯科が大切にしている3つの約束と診療方針をご紹介します。説明を先に、無理に進めず、必要以上に削らない考え方をお伝えします。"
>
  <PageHero
    title="私たちの考え"
    subtitle="なぜこの医院をつくったのか、お話しします"
    image={VISUALS.consultation.defaultSrc}
    imageWarm={VISUALS.consultation.warmSrc}
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "私たちの考え" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <p class="eyebrow">大切にしていること</p>
      <h2 class="section-title">この医院の3つの約束</h2>
      <p class="section-lead">
        派手な言葉ではなく、毎回の診療で守ることを決めています。
      </p>

      <div class="promise-stack">
        {THREE_PROMISES.map((promise, index) => (
          <article class="promise-row">
            <div class="promise-mark">{String(index + 1).padStart(2, "0")}</div>
            <div class="promise-body card">
              <p class="promise-kicker">約束 0{index + 1}</p>
              <h3>{promise.title}</h3>
              <p>{promise.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-alt">
    <div class="container-narrow policy-grid">
      <article class="policy-card card">
        <h3>専門用語は使いません</h3>
        <p>
          今のお口の状態、考えられる治療、通院の目安は、普段の言葉でお伝えします。
          何をするか言わずに進めることはありません。わからないまま治療台に座らせることもしません。
        </p>
      </article>
      <article class="policy-card card">
        <h3>圧をかけません</h3>
        <p>
          「怖い」「しみる」「怒られそう」「久しぶりで気まずい」。
          その気持ちを抱えたまま来てくださる方が多いからこそ、こちらから急かしたり、決断を迫ったりはしません。
        </p>
      </article>
      <article class="policy-card card">
        <h3>治して終わり、にはしません</h3>
        <p>
          痛みが取れたら終わりではなく、繰り返さないところまで一緒に考えます。
          虫歯や歯周病の治療後も、定期管理やクリーニングを含めてご案内します。
        </p>
      </article>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow split-grid">
      <div>
        <p class="eyebrow">診療への考え方</p>
        <h2 class="section-title-left">先に説明して、納得してから進める。そこは変えません。</h2>
        <p>
          歯科治療は、痛みや費用への不安がつきものです。だからこそ当院では、
          お口の状態だけでなく、患者さんが何をいちばん気にしているかを最初にうかがいます。
        </p>
        <p>
          必要以上に削らないこと。押し付けないこと。説明を省かないこと。
          派手なことではありませんが、その積み重ねが「また来よう」と思える通いやすさになると考えています。
        </p>
      </div>
      <div class="split-panel card">
        <p class="panel-title">診療で大切にしていること</p>
        <ul class="panel-list">
          <li>痛いときは、まずその痛みを和らげます</li>
          <li>治療の選択肢は、省かずにお話しします</li>
          <li>費用や通院回数も、先にお伝えします</li>
          <li>迷っている段階なら、相談だけでも大丈夫です</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding bg-section">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">初診のご案内</p>
        <h2>初めての方は、こちらもご覧ください。</h2>
        <p>いきなり治療はしません。初診の流れや持ち物を、先にまとめています。</p>
      </div>
      <a href="/first-visit/" class="btn-primary">初めての方へ</a>
    </div>
  </section>

  <SectionCTA
    heading="初めての方は、こちらもご覧ください。"
    text="初診の流れや持ち物を、先に確認できるようにまとめています。"
  />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: 1.9rem;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .section-lead {
    color: var(--color-text-light);
    line-height: 1.85;
    max-width: 680px;
    margin-bottom: 2rem;
  }
  .promise-stack {
    display: grid;
    gap: 1.25rem;
  }
  .promise-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.25rem;
    align-items: center;
  }
  .promise-mark {
    font-size: clamp(3.2rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--color-primary-light);
    line-height: 1;
    text-align: center;
  }
  .promise-body {
    padding: 2rem;
  }
  .promise-kicker {
    letter-spacing: 0.18em;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .promise-body h3,
  .policy-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }
  .promise-body p,
  .policy-card p,
  .split-grid p {
    line-height: 1.9;
    color: var(--color-text-light);
  }
  .policy-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .policy-card {
    padding: 2rem;
  }
  .split-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }
  .split-panel {
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(43, 107, 138, 0.06), transparent),
      var(--color-bg);
  }
  .panel-title {
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .panel-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }
  .panel-list li {
    padding-left: 1.4rem;
    position: relative;
    line-height: 1.8;
    color: var(--color-text);
  }
  .panel-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent-light);
    box-shadow: inset 0 0 0 2px var(--color-accent);
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .policy-grid,
    .split-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
    .promise-row {
      grid-template-columns: 1fr;
    }
    .promise-mark {
      text-align: left;
    }
  }
</style>
