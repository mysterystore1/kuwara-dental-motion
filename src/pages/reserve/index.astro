---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE } from "../../data/site";
import { VISUALS } from "../../data/visualAssets";
---

<BaseLayout title="ご予約・ご相談" description="辻堂がじゅまる歯科のご予約はEPARK・LINE・お電話から。お気軽にご連絡ください。">
  <PageHero title="ご予約・ご相談" subtitle="お気軽にお問い合わせください" image={VISUALS.reception.defaultSrc} imageWarm={VISUALS.reception.warmSrc} />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "ご予約・ご相談" }]} />
  </div>

  <!-- ========== 予約方法 ========== -->
  <section class="reserve-methods section-padding">
    <div class="container-narrow">
      <h2 class="section-title">ご予約方法</h2>
      <p class="section-lead">3つの方法からお選びいただけます</p>

      <div class="methods-grid">
        <!-- EPARK -->
        <div class="method-card card">
          <div class="method-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect x="8" y="6" width="32" height="36" rx="4" stroke="var(--color-primary)" stroke-width="2" fill="var(--color-primary-light)"/>
              <path d="M16 16h16M16 24h16M16 32h10" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>EPARK WEB予約</h3>
          <p class="method-badge">24時間受付</p>
          <p class="method-desc">スマホ・PCからいつでもご予約いただけます。空き状況をリアルタイムで確認できます。</p>
          <a href={SITE.reserve.epark} class="btn-primary method-btn" target="_blank" rel="noopener noreferrer">WEB予約はこちら</a>
        </div>

        <!-- LINE -->
        <div class="method-card card">
          <div class="method-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect x="8" y="8" width="32" height="32" rx="8" fill="#06C755"/>
              <path d="M16 28c0-6.627 5.373-10 8-10s8 3.373 8 10" stroke="#fff" stroke-width="2"/>
              <circle cx="20" cy="24" r="1.5" fill="#fff"/>
              <circle cx="28" cy="24" r="1.5" fill="#fff"/>
            </svg>
          </div>
          <h3>LINE予約</h3>
          <p class="method-badge">チャットで気軽に</p>
          <p class="method-desc">LINEでお友だち登録いただくと、トーク画面からご予約・ご相談ができます。</p>
          <div class="line-qr-placeholder">
            <p>LINEお友だち追加<br />QRコード（後で設置）</p>
          </div>
          <a href={SITE.reserve.line} class="btn-line method-btn" target="_blank" rel="noopener noreferrer">LINEで予約する</a>
        </div>

        <!-- 電話 -->
        <div class="method-card card">
          <div class="method-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <path d="M14 10c-2 0-4 2-4 4 0 12 10 22 22 22 2 0 4-2 4-4l-4-6-4 2c-4-2-8-6-10-10l2-4-6-4z" fill="var(--color-primary-light)" stroke="var(--color-primary)" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>お電話</h3>
          <p class="method-badge">直接お話しできます</p>
          <p class="phone-number">
            <a href={SITE.phoneHref}>{SITE.phone}</a>
          </p>
          <p class="method-desc">
            受付時間:<br />
            月火水金 {SITE.hours.weekday}<br />
            土 {SITE.hours.saturday}
          </p>
          <a href={SITE.phoneHref} class="btn-primary method-btn btn-phone">電話をかける</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 初めての方へ ========== -->
  <section class="first-visit-link section-padding bg-alt">
    <div class="container-narrow first-visit-inner">
      <div class="first-visit-text">
        <h2 class="section-title-left">初めての方へ</h2>
        <p>
          当院では、初めてご来院いただく方にも安心していただけるよう、まずはカウンセリングからスタートします。
          いきなり治療を始めることはありません。持ち物やご来院の流れについてもご案内しています。
        </p>
        <a href="/first-visit/" class="btn-secondary" style="margin-top:1.5rem;">初めての方へのご案内</a>
      </div>
    </div>
  </section>

  <!-- ========== 診療時間 ========== -->
  <section class="hours-section section-padding">
    <div class="container-narrow">
      <h2 class="section-title">診療時間</h2>

      <div class="hours-table-wrap">
        <table class="hours-table">
          <thead>
            <tr>
              <th></th>
              <th>月</th>
              <th>火</th>
              <th>水</th>
              <th>木</th>
              <th>金</th>
              <th>土</th>
              <th>日・祝</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="time-label">9:30 - 13:00</td>
              <td>○</td>
              <td>○</td>
              <td>○</td>
              <td>-</td>
              <td>○</td>
              <td>○</td>
              <td>-</td>
            </tr>
            <tr>
              <td class="time-label">14:30 - 19:00</td>
              <td>○</td>
              <td>○</td>
              <td>○</td>
              <td>-</td>
              <td>○</td>
              <td>△</td>
              <td>-</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="hours-note">△ 土曜午後は 14:30 - 17:00</p>
      <p class="hours-note">休診日: {SITE.hours.closed}</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Section Titles ---------- */
  .section-title {
    font-size: 1.75rem;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .section-title-left {
    font-size: 1.5rem;
    text-align: left;
    margin-bottom: 1rem;
  }
  .section-lead {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: 2.5rem;
  }

  /* ---------- Methods Grid ---------- */
  .methods-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .method-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1.5rem;
  }
  .method-icon {
    margin-bottom: 1rem;
  }
  .method-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .method-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }
  .method-desc {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  .method-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.95rem;
  }

  /* LINE specific */
  .btn-line {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background-color: #06C755;
    color: #fff;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: background-color 0.2s, transform 0.15s;
    text-decoration: none;
    width: 100%;
  }
  .btn-line:hover {
    background-color: #05a847;
    color: #fff;
    transform: translateY(-1px);
  }
  .line-qr-placeholder {
    background: var(--color-bg-alt);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-sm);
    width: 140px;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  /* Phone specific */
  .phone-number {
    margin-bottom: 0.75rem;
  }
  .phone-number a {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }
  .btn-phone {
    background: var(--color-primary);
  }
  .btn-phone:hover {
    background: var(--color-primary-dark);
  }

  @media (max-width: 768px) {
    .methods-grid {
      grid-template-columns: 1fr;
    }
    .method-card {
      padding: 2rem 1.5rem;
    }
  }

  /* ---------- First Visit ---------- */
  .first-visit-inner {
    max-width: 720px;
  }
  .first-visit-text p {
    line-height: 1.9;
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  /* ---------- Hours Table ---------- */
  .hours-table-wrap {
    max-width: 600px;
    margin: 1.5rem auto 0;
    overflow-x: auto;
  }
  .hours-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    text-align: center;
  }
  .hours-table th {
    background: var(--color-primary-light);
    padding: 0.6rem 0.5rem;
    font-weight: 600;
    color: var(--color-text-heading);
  }
  .hours-table td {
    padding: 0.6rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .hours-table .time-label {
    text-align: left;
    font-weight: 600;
    font-size: 0.85rem;
    white-space: nowrap;
  }
  .hours-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.4rem;
  }
</style>
