---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionCTA from "../components/SectionCTA.astro";
import DentalIcon from "../components/DentalIcon.astro";
import { SITE, THREE_PROMISES } from "../data/site";

const symptomItems = [
  {
    href: "/symptoms/toothache/",
    title: "歯が痛い",
    description: "ズキズキ痛む、噛むと痛い、夜になるとつらい",
    icon: "tooth",
  },
  {
    href: "/symptoms/sensitivity/",
    title: "歯がしみる",
    description: "冷たいものや甘いものでキーンとする",
    icon: "spark",
  },
  {
    href: "/symptoms/swollen-gums/",
    title: "歯茎が腫れた",
    description: "歯ぐきの腫れ、出血、違和感がある",
    icon: "gum",
  },
  {
    href: "/symptoms/lost-filling/",
    title: "詰め物が取れた",
    description: "外れたままにせず、まずは状態を確認します",
    icon: "hand",
  },
] as const;

const serviceItems = [
  { href: "/services/cavity/", title: "虫歯治療", description: "できるだけ歯を残しながら治療します", icon: "tooth" },
  { href: "/services/periodontal/", title: "歯周病治療", description: "歯ぐきと歯を支える骨の健康を守ります", icon: "gum" },
  { href: "/services/preventive/", title: "予防歯科", description: "定期管理で再発しにくい口内環境を目指します", icon: "shield" },
  { href: "/services/pediatric/", title: "小児歯科", description: "お子さまのペースに合わせて進めます", icon: "child" },
  { href: "/services/whitening/", title: "ホワイトニング", description: "自然な明るさを目指す審美ケアです", icon: "whitening" },
] as const;

const reasonItems = [
  {
    number: "01",
    title: "初診は、いきなり治療から始めません",
    text: "まずは困っていることや不安に思っていることをうかがい、必要な検査とご説明から進めます。相談だけで終わっても構いません。",
    image: "https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=900&q=80&auto=format&fit=crop",
    alt: "カウンセリングの様子",
  },
  {
    number: "02",
    title: "痛みや怖さに配慮しながら進めます",
    text: "麻酔の方法や治療の進め方は、お口の状態と患者さまのご不安に合わせて調整します。つらいときは、その場で止めながら進めます。",
    image: "https://images.unsplash.com/photo-1609840114035-3c981b782dfe?w=900&q=80&auto=format&fit=crop",
    alt: "歯科治療の風景",
  },
  {
    number: "03",
    title: "治療内容を、できるだけわかりやすく説明します",
    text: "今どんな状態なのか、どの治療が必要なのか、通院回数の目安まで、診療チェアの上で置いていかない説明を心がけています。",
    image: "https://images.unsplash.com/photo-1629909615184-74f495363b67?w=900&q=80&auto=format&fit=crop",
    alt: "明るい受付と待合スペース",
  },
] as const;

const faqPreview = [
  {
    q: "初診の所要時間はどれくらいですか？",
    a: "問診、必要な検査、カウンセリングを含めて45分から1時間ほどを目安にしています。痛みが強い場合は応急処置を優先します。",
  },
  {
    q: "久しぶりの歯医者でも大丈夫ですか？",
    a: "大丈夫です。お口の状態を責めることはありません。今の状態からどう整えていくかを、一緒に考えていきます。",
  },
  {
    q: "予約なしでも診てもらえますか？",
    a: "急な痛みがある場合は、できる限り対応します。まずはお電話でご連絡いただくとご案内がスムーズです。",
  },
] as const;
---

<BaseLayout
  title="歯医者が久しぶりの方も、安心して相談できる歯科医院"
  description="初診はカウンセリングと必要な検査から。歯医者が怖い方、久しぶりの方も相談しやすいよう、丁寧な説明と痛みに配慮した診療を大切にしています。"
>
  <section class="home-hero wave-divider">
    <div class="container-narrow home-hero__inner">
      <div class="home-hero__copy">
        <p class="section-kicker">初診のご案内</p>
        <p class="home-hero__clinic">{SITE.name}</p>
        <h1 class="home-hero__title">歯医者が久しぶりの方も、<br />安心してご相談ください。</h1>
        <p class="home-hero__text">
          {SITE.name}では、まず困っていることをうかがい、お口の状態を確認したうえで、
          必要な検査とご説明から進めます。治療を急がせず、相談しやすい距離感を大切にしています。
        </p>

        <div class="home-hero__actions">
          <a href="/reserve/" class="btn-primary">WEB予約へ進む</a>
          <a href="/first-visit/" class="btn-secondary">初めての方へ</a>
        </div>

        <div class="home-hero__chips">
          <span class="icon-chip"><DentalIcon name="pin" size={18} /> {SITE.address.station}</span>
          <span class="icon-chip"><DentalIcon name="clock" size={18} /> 平日19時まで診療</span>
          <span class="icon-chip"><DentalIcon name="chat" size={18} /> まずは相談からでも可</span>
        </div>
      </div>

      <div class="home-hero__visual">
        <div class="hero-orb hero-orb--one"></div>
        <div class="hero-orb hero-orb--two"></div>
        <figure class="hero-photo hero-photo--main">
          <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=1100&q=80&auto=format&fit=crop" alt="明るい歯科医院の待合室" loading="eager" />
        </figure>
        <figure class="hero-photo hero-photo--card">
          <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=700&q=80&auto=format&fit=crop" alt="カウンセリングの様子" loading="eager" />
          <figcaption>
            <span class="eyebrow">ご相談について</span>
            <strong>まずはお口の状態を確認し、進め方をわかりやすくご説明します。</strong>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section-padding blob-section">
    <div class="container-narrow reassurance">
      <div class="reassurance__lead">
        <p class="section-kicker">ご来院前に</p>
        <h2 class="section-title">来院前の不安を、少しでも軽くできるように。</h2>
        <p class="section-lead">
          歯科医院を探すときは、治療の内容だけでなく、どんなふうに話を聞いてもらえるかも気になるものです。
          まずは来院前の不安をやわらげることを大切にしています。
        </p>
      </div>

      <div class="reassurance__layout">
        <div class="reassurance__chips">
          <span class="reassurance__chip">何年も歯医者に行っていない</span>
          <span class="reassurance__chip">怒られそうで行きづらい</span>
          <span class="reassurance__chip">痛い治療のイメージが強い</span>
          <span class="reassurance__chip">まずは相談だけしたい</span>
        </div>

        <div class="reassurance__panel">
          <p class="eyebrow">当院の考え方</p>
          <h3>今のお困りごとをうかがい、できることから整理します。</h3>
          <p>
            すぐに治療を始めるのではなく、痛みの有無やご不安、ご希望をうかがったうえで、
            必要な検査や応急対応をご案内します。説明を聞いてから考えたい方にも、無理のない形で進めます。
          </p>
          <a href="/dental-anxiety/" class="btn-secondary">歯医者が怖い方へ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding promise-section">
    <div class="container-narrow">
      <p class="section-kicker">3つの約束</p>
      <h2 class="section-title">診療の土台にしている3つの約束</h2>
      <div class="promise-rows">
        {reasonItems.map((item, index) => (
          <article class:list={["promise-row", index % 2 === 1 && "reverse"]}>
            <div class="promise-row__visual shape-wrap">
              <img src={item.image} alt={item.alt} loading="lazy" />
            </div>
            <div class="promise-row__copy">
              <span class="promise-row__number">{item.number}</span>
              <p class="section-kicker">約束 {item.number}</p>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="promise-summary">
        {THREE_PROMISES.map((promise) => (
          <div class="promise-summary__item soft-panel">
            <span class="promise-summary__icon">
              <DentalIcon name={promise.icon === "shield" ? "shield" : promise.icon === "heart" ? "heart" : "hand"} size={24} />
            </span>
            <div>
              <h3>{promise.title}</h3>
              <p>{promise.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding first-step">
    <div class="container-narrow first-step__inner">
      <div class="first-step__copy">
        <p class="section-kicker">初診の流れ</p>
        <h2 class="section-title">初診では、今のお困りごとを整理することから始めます。</h2>
        <p class="section-lead">
          初回は問診、必要な検査、カウンセリング、ご説明が中心です。強い痛みがある場合は、応急的な処置を優先します。
        </p>
        <div class="first-step__grid">
          <div class="soft-panel">
            <p class="first-step__label">Step 01</p>
            <h3>ご予約・受付</h3>
            <p>WEB、LINE、お電話からご予約いただけます。初診の方はご予約時間の10分前を目安にお越しください。</p>
          </div>
          <div class="soft-panel">
            <p class="first-step__label">Step 02</p>
            <h3>カウンセリングと検査</h3>
            <p>気になっている症状や不安をうかがい、必要に応じてレントゲンや口腔内写真で状態を確認します。</p>
          </div>
          <div class="soft-panel">
            <p class="first-step__label">Step 03</p>
            <h3>ご説明と今後のご提案</h3>
            <p>現在の状態、必要な治療、通院の目安をご説明し、ご希望に合わせた進め方をご案内します。</p>
          </div>
        </div>
        <div class="first-step__links">
          <a href="/first-visit/" class="btn-primary">初診の流れを見る</a>
          <a href="/faq/" class="btn-secondary">持ち物とよくあるご質問</a>
        </div>
      </div>

      <div class="first-step__visual shape-wrap">
        <img src="https://images.unsplash.com/photo-1609840114035-3c981b782dfe?w=1000&q=80&auto=format&fit=crop" alt="診療の説明を受ける患者さま" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section-padding symptoms-overview blob-section">
    <div class="container-narrow">
      <div class="section-header">
        <p class="section-kicker">症状から探す</p>
        <h2 class="section-title">気になる症状から、必要なページへ進めます。</h2>
        <p class="section-lead">
          今つらい症状がある方は、原因や受診の目安をまとめた症状ページからご覧ください。
        </p>
      </div>

      <div class="symptoms-overview__grid">
        {symptomItems.map((item) => (
          <a href={item.href} class="symptoms-overview__card">
            <span class="symptoms-overview__icon">
              <DentalIcon name={item.icon as any} size={34} />
            </span>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding services-overview">
    <div class="container-narrow">
      <div class="section-header">
        <p class="section-kicker">診療内容</p>
        <h2 class="section-title">お悩みに合わせた診療内容をご案内します。</h2>
        <p class="section-lead">
          どの診療が自分に合っているかわからない場合も、症状と合わせてご確認いただけます。
        </p>
      </div>

      <div class="services-overview__grid">
        {serviceItems.map((item) => (
          <a href={item.href} class="services-overview__item">
            <span class="services-overview__icon">
              <DentalIcon name={item.icon as any} size={32} />
            </span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding doctor-highlight">
    <div class="container-narrow doctor-highlight__inner">
      <div class="doctor-highlight__copy">
        <p class="section-kicker">院長より</p>
        <h2 class="section-title">患者さまのペースを大切にしながら、必要な治療をご提案します。</h2>
        <p class="section-lead">
          「どこまで治療するか」「まず何を優先するか」は、生活背景やご希望によって変わります。説明を丁寧に行い、無理なく通える進め方を一緒に考えていきます。
        </p>
        <div class="doctor-highlight__quote soft-panel">
          <p>痛みや不安が強い方にも、まずは落ち着いて話せる診療室でありたいと考えています。小さな違和感でも遠慮なくご相談ください。</p>
        </div>
        <a href="/clinic/doctor/" class="btn-secondary">院長紹介を見る</a>
      </div>

      <div class="doctor-highlight__visual">
        <figure class="doctor-highlight__portrait">
          <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=900&q=80&auto=format&fit=crop" alt="歯科医師のポートレート" loading="lazy" />
        </figure>
        <figure class="doctor-highlight__support">
          <img src="https://images.unsplash.com/photo-1588776814546-daab30f310ce?w=900&q=80&auto=format&fit=crop" alt="診療室の設備" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <section class="section-padding clinic-preview blob-section">
    <div class="container-narrow">
      <div class="section-header">
        <p class="section-kicker">院内紹介</p>
        <h2 class="section-title">受付から診療室まで、落ち着いて過ごせる空間づくりを心がけています。</h2>
      </div>

      <div class="clinic-preview__grid">
        <figure class="clinic-preview__photo clinic-preview__photo--large">
          <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=1200&q=80&auto=format&fit=crop" alt="明るい待合スペース" loading="lazy" />
        </figure>
        <figure class="clinic-preview__photo">
          <img src="https://images.unsplash.com/photo-1629909615184-74f495363b67?w=900&q=80&auto=format&fit=crop" alt="受付カウンター" loading="lazy" />
        </figure>
        <figure class="clinic-preview__photo">
          <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?w=900&q=80&auto=format&fit=crop" alt="診療チェア" loading="lazy" />
        </figure>
      </div>

      <div class="clinic-preview__link">
        <a href="/clinic/facility/" class="btn-secondary">院内紹介を見る</a>
      </div>
    </div>
  </section>

  <section class="section-padding faq-preview">
    <div class="container-narrow faq-preview__inner">
      <div class="section-header">
        <p class="section-kicker">よくあるご質問</p>
        <h2 class="section-title">初診前によくいただくご質問</h2>
      </div>

      <div class="faq-preview__list">
        {faqPreview.map((item) => (
          <details class="faq-preview__item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>

      <div class="faq-preview__link">
        <a href="/faq/" class="btn-secondary">FAQをもっと見る</a>
      </div>
    </div>
  </section>

  <section class="section-padding access-preview">
    <div class="container-narrow access-preview__inner">
      <div class="access-preview__copy">
        <p class="section-kicker">アクセス</p>
        <h2 class="section-title">駅からの距離、診療時間、連絡先をまとめてご確認いただけます。</h2>
        <dl class="access-preview__list">
          <dt><DentalIcon name="pin" size={18} /> 住所</dt>
          <dd>{SITE.address.full}</dd>
          <dt><DentalIcon name="clock" size={18} /> 診療時間</dt>
          <dd>月火水金 {SITE.hours.weekday}<br />土 {SITE.hours.saturday}</dd>
          <dt><DentalIcon name="phone" size={18} /> 電話番号</dt>
          <dd><a href={SITE.phoneHref}>{SITE.phone}</a></dd>
        </dl>
        <div class="access-preview__actions">
          <a href="/access/" class="btn-primary">アクセスを見る</a>
          <a href="/reserve/" class="btn-secondary">予約方法を見る</a>
        </div>
      </div>

      <div class="access-preview__map soft-panel">
        <p class="eyebrow">所在地</p>
        <strong>{SITE.address.station}</strong>
        <p>地図埋め込みは本番時に差し替え予定です。駅からの道順、駐車場情報、診療時間をアクセスページにまとめています。</p>
        <div class="access-preview__placeholder">
          <DentalIcon name="pin" size={28} />
          <span>Google Maps を後で埋め込み</span>
        </div>
      </div>
    </div>
  </section>

  <SectionCTA />
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    padding: clamp(2.6rem, 5vw, 4.6rem) 0 5.2rem;
    overflow: hidden;
    background:
      radial-gradient(circle at left top, rgba(125, 173, 200, 0.22), transparent 34%),
      radial-gradient(circle at right 15%, rgba(219, 139, 87, 0.14), transparent 26%),
      linear-gradient(180deg, #fff9f1 0%, #f4f9fd 100%);
  }

  .home-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 2rem;
    align-items: center;
  }

  .home-hero__copy {
    position: relative;
    z-index: 1;
    max-width: 37rem;
  }

  .home-hero__clinic {
    margin-top: 0.8rem;
    color: var(--color-text-soft);
    letter-spacing: 0.08em;
    font-size: 0.9rem;
  }

  .home-hero__title {
    margin-top: 0.55rem;
    font-size: clamp(2.7rem, 5.4vw, 5.1rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .home-hero__text {
    margin-top: 1.2rem;
    color: var(--color-text);
    font-size: 1rem;
    max-width: 34rem;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.6rem;
  }

  .home-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.55rem;
  }

  .home-hero__visual {
    position: relative;
    min-height: 34rem;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(2px);
  }

  .hero-orb--one {
    top: 6%;
    right: 5%;
    width: 12rem;
    height: 12rem;
    background: rgba(125, 173, 200, 0.12);
  }

  .hero-orb--two {
    left: 5%;
    bottom: 10%;
    width: 8.5rem;
    height: 8.5rem;
    background: rgba(219, 139, 87, 0.12);
  }

  .hero-photo {
    position: absolute;
    overflow: hidden;
    box-shadow: var(--shadow-float);
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-photo--main {
    inset: 2% 2% 18% 16%;
    border-radius: 38% 62% 46% 54% / 52% 42% 58% 48%;
  }

  .hero-photo--card {
    inset: auto auto 0 0;
    width: min(20rem, 58%);
    border-radius: 1.7rem;
    background: rgba(255,255,255,0.92);
  }

  .hero-photo--card img {
    aspect-ratio: 4 / 3;
  }

  .hero-photo--card figcaption {
    display: grid;
    gap: 0.4rem;
    padding: 1.05rem 1.15rem 1.15rem;
  }

  .hero-photo--card strong {
    color: var(--color-ink);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .reassurance__lead,
  .section-header {
    display: grid;
    justify-items: start;
    gap: 0.22rem;
    margin-bottom: 2rem;
  }

  .reassurance__layout {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .reassurance__chips {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .reassurance__chip {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(125, 173, 200, 0.16);
    background: rgba(255,255,255,0.92);
    box-shadow: 0 18px 34px rgba(27, 53, 82, 0.08);
    color: var(--color-ink);
    font-weight: 600;
  }

  .reassurance__chip:nth-child(2n) {
    margin-left: auto;
    background: rgba(255, 241, 231, 0.92);
  }

  .reassurance__panel {
    padding: clamp(1.6rem, 3vw, 2.4rem);
    border-radius: 2.2rem;
