---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionCTA from "../components/SectionCTA.astro";
import DentalIcon from "../components/DentalIcon.astro";
import ThemedImage from "../components/ThemedImage.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import { SITE, THREE_PROMISES } from "../data/site";
import { VISUALS } from "../data/visualAssets";

const heroSlides = [
  {
    defaultSrc: VISUALS.heroWelcome.defaultSrc,
    warmSrc: VISUALS.heroWelcome.warmSrc,
    alt: VISUALS.heroWelcome.alt,
    label: "ご来院時",
    title: "まずは、話を聞くところから。",
    description: "来院した瞬間から緊張が少しほどけるように、明るさと声かけのやわらかさを大切にしています。",
  },
  {
    defaultSrc: VISUALS.consultation.defaultSrc,
    warmSrc: VISUALS.consultation.warmSrc,
    alt: VISUALS.consultation.alt,
    label: "カウンセリング",
    title: "何が不安かを、先にうかがいます。",
    description: "今つらいこと、前の歯医者で嫌だったこと、今回いちばん気になっていることから整理します。",
  },
  {
    defaultSrc: VISUALS.pediatric.defaultSrc,
    warmSrc: VISUALS.pediatric.warmSrc,
    alt: VISUALS.pediatric.alt,
    label: "ご家族で通院",
    title: "親子でも通いやすい空気感を。",
    description: "お子さま連れでも身構えすぎずに来られるように、やわらかい雰囲気と説明のわかりやすさを整えています。",
  },
] as const;

const symptomItems = [
  {
    href: "/symptoms/toothache/",
    title: "歯が痛い",
    description: "ズキズキ痛む、噛むと痛い、夜になるとつらい",
    icon: "tooth",
  },
  {
    href: "/symptoms/sensitivity/",
    title: "歯がしみる",
    description: "冷たいものや甘いものでキーンとする",
    icon: "spark",
  },
  {
    href: "/symptoms/swollen-gums/",
    title: "歯茎が腫れた",
    description: "歯ぐきの腫れ、出血、違和感がある",
    icon: "gum",
  },
  {
    href: "/symptoms/lost-filling/",
    title: "詰め物が取れた",
    description: "外れたままにせず、まずは状態を確認します",
    icon: "hand",
  },
] as const;

const serviceItems = [
  { href: "/services/cavity/", title: "虫歯治療", description: "削る量を抑えながら治療します", icon: "tooth" },
  { href: "/services/periodontal/", title: "歯周病治療", description: "歯ぐきと歯を支える骨の健康を守ります", icon: "gum" },
  { href: "/services/preventive/", title: "予防歯科", description: "定期管理で再発しにくい口内環境を目指します", icon: "shield" },
  { href: "/services/pediatric/", title: "小児歯科", description: "お子さまのペースに合わせて進めます", icon: "child" },
  { href: "/services/whitening/", title: "ホワイトニング", description: "自然な明るさを目指す審美ケアです", icon: "whitening" },
] as const;

const promiseItems = [
  {
    number: "01",
    badge: "初回はカウンセリング中心",
    title: "まず、お話を聞かせてください。",
    text: "初回はカウンセリングが中心です。いきなり治療は始めません。相談だけで終わっても大丈夫です。",
    points: ["相談だけでも大丈夫です", "前の歯医者で嫌だったことも話せます"],
    imageDefault: VISUALS.consultation.defaultSrc,
    imageWarm: VISUALS.consultation.warmSrc,
    alt: "カウンセリングの様子",
  },
  {
    number: "02",
    badge: "痛みに配慮した進め方",
    title: "怖くなったら、手を挙げてください。",
    text: "痛かったり怖くなったりしたら、その場で止めます。我慢したまま進めることはしません。",
    points: ["痛かったら、その場で止めます", "表面麻酔や声かけで緊張を和らげます"],
    imageDefault: VISUALS.treatment.defaultSrc,
    imageWarm: VISUALS.treatment.warmSrc,
    alt: "歯科治療の風景",
  },
  {
    number: "03",
    badge: "説明を先にする診療",
    title: "何をするか、先にきちんとお伝えします。",
    text: "今の状態、必要な治療、通院の目安まで、先にお話しします。わからないまま口の中を触ることはありません。",
    points: ["専門用語を使いすぎません", "納得してから治療を始めます"],
    imageDefault: VISUALS.doctorPortrait.defaultSrc,
    imageWarm: VISUALS.doctorPortrait.warmSrc,
    alt: "やわらかな表情で迎える歯科医師",
  },
] as const;

const benefitItems = [
  {
    icon: "shield",
    label: "痛みに配慮",
    title: "痛みが苦手な方も、相談しやすい進め方です。",
    text: "表面麻酔や細い針、声かけを組み合わせながら進めます。怖くなったら、その場で止められます。",
    points: ["我慢したまま進めません", "急な痛みには応急処置も行います"],
  },
  {
    icon: "heart",
    label: "責めない対応",
    title: "何年ぶりでも大丈夫。責めずに今からを考えます。",
    text: "来院が空いてしまったことを責めるのではなく、今のお口の状態からどう整えるかを一緒に考えます。",
    points: ["怒られるのが苦手な方へ", "久しぶりでも歓迎です"],
  },
  {
    icon: "chat",
    label: "相談しやすさ",
    title: "何をするかがわかるから、不安が残りにくい。",
    text: "今の状態、必要な治療、通院の目安まで先にお伝えします。説明を聞いてから決めていただけます。",
    points: ["初回はお話が中心です", "相談だけで終わっても大丈夫です"],
  },
] as const;

const faqPreview = [
  {
    q: "初診の所要時間はどれくらいですか？",
    a: "初回は1時間ほどいただいています。急かさずお話を聞く時間も含んでいます。痛みが強い場合は、先に応急処置を行うこともあります。",
  },
  {
    q: "久しぶりの歯医者でも大丈夫ですか？",
    a: "大丈夫です。何年ぶりでも歓迎です。今の状態を確認して、ここからどう整えるかを一緒に考えます。",
  },
  {
    q: "予約なしでも診てもらえますか？",
    a: "急な痛みがある場合は、できる限り対応します。まずはお電話でご連絡いただくとご案内がスムーズです。",
  },
] as const;
---

<BaseLayout
  title="「怖い」を我慢しなくていい歯科医院"
  description="歯医者がこわくて、なかなか行けていない方へ。何年ぶりでも大丈夫です。まずは話を聞くところから始めます。"
>
  <section class="home-hero wave-divider">
    <div class="container-narrow home-hero__inner">
      <div class="home-hero__copy" data-reveal data-reveal-origin="left">
        <p class="section-kicker">ご来院をご検討の方へ</p>
        <p class="home-hero__clinic">{SITE.name}</p>
        <h1 class="home-hero__title">歯医者がこわくて、<br />なかなか行けていない方へ。</h1>
        <p class="home-hero__promise">まずはお話を聞くところから始めます。</p>
        <p class="home-hero__text">
          痛みが苦手な方も、怒られるのが苦手な方も大丈夫です。無理に治療を進めることはありません。
        </p>

        <div class="home-hero__microcopy">
          <span>痛みが苦手な方へ</span>
          <span>怒られるのが苦手な方へ</span>
          <span>相談だけでも大丈夫です</span>
        </div>

        <div class="home-hero__notice">
          <p class="eyebrow">ご予約前に</p>
          <p class="home-hero__notice-main">何をすればいいかわからなくても、そのままで大丈夫です。</p>
          <p class="home-hero__notice-sub">今つらいところや、気になっていることをお聞かせください。</p>
        </div>

        <div class="home-hero__actions">
          <a href="/reserve/" class="btn-primary">WEB予約する</a>
          <a href={SITE.phoneHref} class="btn-secondary">電話で相談</a>
          <a href="/first-visit/" class="btn-secondary home-hero__link">初めての方へ</a>
        </div>

        <div class="home-hero__chips">
          <span class="icon-chip"><DentalIcon name="pin" size={18} /> {SITE.address.station}</span>
          <span class="icon-chip"><DentalIcon name="clock" size={18} /> 平日19時まで診療</span>
          <span class="icon-chip"><DentalIcon name="chat" size={18} /> 相談だけでも大丈夫です</span>
        </div>
      </div>

      <div class="home-hero__visual" data-reveal data-reveal-origin="right" style="--reveal-delay: 120ms;">
        <div class="hero-orb hero-orb--one"></div>
        <div class="hero-orb hero-orb--two"></div>
        <ThemedImage
          defaultSrc={VISUALS.decorSpark.defaultSrc}
          warmSrc={VISUALS.decorSpark.warmSrc}
          alt=""
          class="decor-float decor-float--spark home-hero__spark"
          loading="eager"
        />
        <ThemedImage
          defaultSrc={VISUALS.decorLoop.defaultSrc}
          warmSrc={VISUALS.decorLoop.warmSrc}
          alt=""
          class="decor-float decor-float--loop home-hero__loop"
          loading="eager"
        />
        <HeroCarousel slides={heroSlides} />
      </div>
    </div>
  </section>

  <section class="section-padding blob-section">
    <div class="container-narrow reassurance">
      <div class="reassurance__lead" data-reveal>
        <p class="section-kicker">ご来院前に</p>
        <h2 class="section-title">こんな不安、ありませんか？</h2>
        <p class="section-lead">
          「何をされるか」より、「どう扱われるか」が気になって、足が向かない方も多くいらっしゃいます。
        </p>
      </div>

      <div class="reassurance__layout">
        <div class="reassurance__chips">
          <span class="reassurance__chip" data-reveal style="--reveal-delay: 0ms;">何年も歯医者に行っていない</span>
          <span class="reassurance__chip" data-reveal style="--reveal-delay: 80ms;">怒られそうで行きづらい</span>
          <span class="reassurance__chip" data-reveal style="--reveal-delay: 160ms;">痛い治療のイメージが強い</span>
          <span class="reassurance__chip" data-reveal style="--reveal-delay: 240ms;">まずは相談だけしたい</span>
        </div>

        <div class="reassurance__panel" data-reveal style="--reveal-delay: 140ms;">
          <p class="eyebrow">当院の考え方</p>
          <h3>状態を責めず、まずは今のお困りごとをうかがいます。</h3>
          <p>
            「何をされるか」より「どう扱われるか」が不安で足が止まってしまう方もいます。
            だから当院では、すぐに治療を始めるのではなく、今の不安と症状を先に言葉にする時間を大切にしています。
          </p>
          <a href="/dental-anxiety/" class="btn-secondary">歯医者が怖い方へ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding promise-section">
    <div class="container-narrow">
      <div data-reveal>
        <p class="section-kicker">3つの約束</p>
        <h2 class="section-title">診療の土台にしている、3つの約束</h2>
        <p class="section-lead">説明ではなく、この医院の強みとして伝えたい約束です。初めての方にも、一目でわかる形にしています。</p>
      </div>
      <div class="promise-cards">
        {promiseItems.map((item, index) => (
          <article class="promise-card" data-reveal style={`--reveal-delay: ${index * 110}ms;`}>
            <div class="promise-card__media">
              <ThemedImage
                defaultSrc={item.imageDefault}
                warmSrc={item.imageWarm}
                alt={item.alt}
                loading="lazy"
              />
            </div>
            <div class="promise-card__body">
              <div class="promise-card__top">
                <span class="promise-card__number">{item.number}</span>
                <span class="promise-card__badge">{item.badge}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <ul class="promise-card__points">
                {item.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <div class="promise-summary">
        {THREE_PROMISES.map((promise, index) => (
          <div class="promise-summary__item" data-reveal style={`--reveal-delay: ${index * 90}ms;`}>
            <span class="promise-summary__icon">
              <DentalIcon name={promise.icon === "shield" ? "shield" : promise.icon === "heart" ? "heart" : "hand"} size={24} />
            </span>
            <div>
              <h3>{promise.title}</h3>
              <p>{promise.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding first-step">
    <div class="container-narrow first-step__inner">
      <div class="first-step__copy" data-reveal data-reveal-origin="left">
        <p class="section-kicker">初診の流れ</p>
        <h2 class="section-title">初回は、あなたの話を聞く時間です。</h2>
        <p class="section-lead">
          何が気になっているのか、過去にどんなことが嫌だったのか。そこを聞いたうえで、必要な確認とご説明に進みます。
        </p>
        <div class="first-step__grid">
          <div class="soft-panel" data-reveal style="--reveal-delay: 60ms;">
            <p class="first-step__label">Step 01</p>
            <h3>ご予約・受付</h3>
            <p>WEB、LINE、お電話からご予約いただけます。初診の方はご予約時間の10分前を目安にお越しください。</p>
          </div>
          <div class="soft-panel" data-reveal style="--reveal-delay: 140ms;">
            <p class="first-step__label">Step 02</p>
            <h3>カウンセリングと検査</h3>
            <p>気になっている症状や不安をうかがい、必要に応じてレントゲンや口腔内写真で状態を確認します。</p>
          </div>
          <div class="soft-panel" data-reveal style="--reveal-delay: 220ms;">
            <p class="first-step__label">Step 03</p>
            <h3>ご説明と今後のご提案</h3>
            <p>今の状態、必要な治療、通院の目安をお伝えします。どう進めるかは、そのうえで一緒に考えましょう。</p>
          </div>
        </div>
        <div class="first-step__links">
          <a href="/first-visit/" class="btn-primary">初診の流れを見る</a>
          <a href="/faq/" class="btn-secondary">持ち物とよくあるご質問</a>
        </div>
      </div>

      <div class="first-step__visual shape-wrap" data-reveal data-reveal-origin="right" style="--reveal-delay: 160ms;">
        <ThemedImage
          defaultSrc={VISUALS.consultation.defaultSrc}
          warmSrc={VISUALS.consultation.warmSrc}
          alt={VISUALS.consultation.alt}
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="section-padding symptoms-overview blob-section">
    <div class="container-narrow">
      <div class="section-header" data-reveal>
        <p class="section-kicker">症状から探す</p>
        <h2 class="section-title">今つらい症状がある方はこちら</h2>
        <p class="section-lead">
          今つらい症状がある方は、原因や受診の目安をまとめた症状ページからご覧ください。
        </p>
      </div>

      <div class="symptoms-overview__grid">
        {symptomItems.map((item, index) => (
          <a href={item.href} class="symptoms-overview__card" data-reveal style={`--reveal-delay: ${index * 80}ms;`}>
            <span class="symptoms-overview__icon">
              <DentalIcon name={item.icon as any} size={34} />
            </span>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding reasons-section">
    <div class="container-narrow">
      <div class="section-header" data-reveal>
        <p class="section-kicker">選ばれる理由</p>
        <h2 class="section-title">この医院だから、ここなら相談してもよさそうと思える理由</h2>
        <p class="section-lead">
          なんとなく安心そう、で終わらせず、患者さんにとってのメリットが見える形で整理しています。
        </p>
      </div>

      <div class="reasons-grid">
        {benefitItems.map((item, index) => (
          <article class="reason-card" data-reveal style={`--reveal-delay: ${index * 100}ms;`}>
            <div class="reason-card__header">
              <span class="reason-card__icon">
                <DentalIcon name={item.icon as any} size={26} />
              </span>
              <span class="reason-card__label">{item.label}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <ul class="reason-card__points">
              {item.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding services-overview">
    <div class="container-narrow">
      <div class="section-header" data-reveal>
        <p class="section-kicker">診療内容</p>
        <h2 class="section-title">治療内容から知りたい方はこちら</h2>
        <p class="section-lead">
          どの治療が自分に合うのかわからない場合も、症状ページと合わせて確認できます。
        </p>
      </div>

      <div class="services-overview__grid">
        {serviceItems.map((item, index) => (
          <a href={item.href} class="services-overview__item" data-reveal style={`--reveal-delay: ${index * 70}ms;`}>
            <span class="services-overview__icon">
              <DentalIcon name={item.icon as any} size={32} />
            </span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding doctor-highlight">
    <div class="container-narrow doctor-highlight__inner">
      <div class="doctor-highlight__copy" data-reveal data-reveal-origin="left">
        <p class="section-kicker">院長より</p>
        <h2 class="section-title">「ここなら大丈夫」と思ってもらえることが、いちばん大切だと思っています。</h2>
        <p class="section-lead">
          歯医者が苦手な方ほど、来るまでに勇気がいると思っています。だからこそ、いきなり治療を進めるのではなく、まずは安心して話せる時間を大切にしています。
        </p>
        <div class="doctor-highlight__quote soft-panel">
          <p>怖い気持ちのまま来てくださる方に、「来てよかった」と思ってもらえる時間にしたい。それが私たちの役割です。</p>
        </div>
        <a href="/clinic/doctor/" class="btn-secondary">院長紹介を見る</a>
      </div>

      <div class="doctor-highlight__visual" data-reveal data-reveal-origin="right" style="--reveal-delay: 120ms;">
        <figure class="doctor-highlight__portrait">
          <ThemedImage
            defaultSrc={VISUALS.doctorPortrait.defaultSrc}
            warmSrc={VISUALS.doctorPortrait.warmSrc}
            alt={VISUALS.doctorPortrait.alt}
            loading="lazy"
          />
        </figure>
        <figure class="doctor-highlight__support">
          <ThemedImage
            defaultSrc={VISUALS.room.defaultSrc}
            warmSrc={VISUALS.room.warmSrc}
            alt={VISUALS.room.alt}
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>

  <section class="section-padding clinic-preview blob-section">
    <div class="container-narrow">
      <div class="section-header" data-reveal>
        <p class="section-kicker">院内紹介</p>
        <h2 class="section-title">院内の空気感も、安心して通えるかどうかの大事なポイントです。</h2>
      </div>

      <div class="clinic-preview__grid">
        <figure class="clinic-preview__photo clinic-preview__photo--large" data-reveal style="--reveal-delay: 0ms;">
          <ThemedImage
            defaultSrc={VISUALS.reception.defaultSrc}
            warmSrc={VISUALS.reception.warmSrc}
            alt={VISUALS.reception.alt}
            loading="lazy"
          />
        </figure>
        <figure class="clinic-preview__photo" data-reveal style="--reveal-delay: 90ms;">
          <ThemedImage
            defaultSrc={VISUALS.consultation.defaultSrc}
            warmSrc={VISUALS.consultation.warmSrc}
            alt={VISUALS.consultation.alt}
            loading="lazy"
          />
        </figure>
        <figure class="clinic-preview__photo" data-reveal style="--reveal-delay: 180ms;">
          <ThemedImage
            defaultSrc={VISUALS.room.defaultSrc}
            warmSrc={VISUALS.room.warmSrc}
            alt={VISUALS.room.alt}
            loading="lazy"
          />
        </figure>
      </div>

      <div class="clinic-preview__link">
        <a href="/clinic/facility/" class="btn-secondary">院内紹介を見る</a>
      </div>
    </div>
  </section>

  <section class="section-padding faq-preview">
    <div class="container-narrow faq-preview__inner">
      <div class="section-header" data-reveal>
        <p class="section-kicker">よくあるご質問</p>
        <h2 class="section-title">初診前によくいただくご質問</h2>
      </div>

      <div class="faq-preview__list">
        {faqPreview.map((item, index) => (
          <details class="faq-preview__item" data-reveal style={`--reveal-delay: ${index * 80}ms;`}>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>

      <div class="faq-preview__link">
        <a href="/faq/" class="btn-secondary">FAQをもっと見る</a>
      </div>
    </div>
  </section>

  <section class="section-padding access-preview">
    <div class="container-narrow access-preview__inner">
      <div class="access-preview__copy" data-reveal data-reveal-origin="left">
