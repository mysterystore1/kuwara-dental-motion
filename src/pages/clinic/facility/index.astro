---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import SectionCTA from "../../../components/SectionCTA.astro";
import { SITE } from "../../../data/site";
import ThemedImage from "../../../components/ThemedImage.astro";
import { VISUALS } from "../../../data/visualAssets";
---

<BaseLayout title="院内紹介" description="辻堂がじゅまる歯科の院内紹介。受付から診療室まで、緊張が少しでも和らぐように整えている空間をご紹介します。">
  <PageHero
    title="院内紹介"
    subtitle="受付から診療室まで、緊張が少しでも和らぐ空間を目指しています。"
    image={VISUALS.reception.defaultSrc}
    imageWarm={VISUALS.reception.warmSrc}
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "医院案内" }, { label: "院内紹介" }]} />
  </div>

  <!-- ========== 院内ギャラリー ========== -->
  <section class="gallery section-padding">
    <div class="container-narrow">
      <h2 class="section-title">院内のご紹介</h2>
      <p class="section-lead">見た目のきれいさだけでなく、なぜこの空間にしているのかもお伝えします。</p>

      <div class="gallery-grid">
        <div class="gallery-item">
          <ThemedImage
            defaultSrc={VISUALS.consultation.defaultSrc}
            warmSrc={VISUALS.consultation.warmSrc}
            alt="ご相談スペース"
            loading="lazy"
          />
          <p class="gallery-caption">ご相談スペース</p>
          <p class="gallery-desc">治療の前後に落ち着いて話せるように、診療チェアとは別の場所をご用意しています。</p>
        </div>
        <div class="gallery-item">
          <ThemedImage
            defaultSrc={VISUALS.room.defaultSrc}
            warmSrc={VISUALS.room.warmSrc}
            alt="診療室"
            loading="lazy"
          />
          <p class="gallery-caption">診療室</p>
          <p class="gallery-desc">明るさと圧迫感の少なさを意識した空間です。入った瞬間の緊張が和らぐように整えています。</p>
        </div>
        <div class="gallery-item">
          <ThemedImage
            defaultSrc={VISUALS.treatment.defaultSrc}
            warmSrc={VISUALS.treatment.warmSrc}
            alt="診療チェア"
            loading="lazy"
          />
          <p class="gallery-caption">半個室の診療スペース</p>
          <p class="gallery-desc">隣の治療音や視線が気になりにくいように、少し落ち着ける距離感をつくっています。</p>
        </div>
        <div class="gallery-item">
          <ThemedImage
            defaultSrc={VISUALS.reception.defaultSrc}
            warmSrc={VISUALS.reception.warmSrc}
            alt="スタッフ"
            loading="lazy"
          />
          <p class="gallery-caption">受付・ご案内</p>
          <p class="gallery-desc">困ったことがあればその場で声をかけていただけるように、話しかけやすい雰囲気を大切にしています。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 設備紹介 ========== -->
  <section class="equipment section-padding bg-alt">
    <div class="container-narrow">
      <h2 class="section-title">設備紹介</h2>
      <p class="section-lead">機械の名前より、患者さんにとって何が安心につながるかでお伝えします。</p>

      <div class="equipment-grid">
        <div class="equipment-card card">
          <h3>被ばく量を抑えたレントゲン</h3>
          <p>被ばく量を抑えながら、撮った画像をその場で確認できます。今どこがどうなっているかを一緒に見ながらお話しします。</p>
        </div>
        <div class="equipment-card card">
          <h3>今の状態が見やすい口腔内カメラ</h3>
          <p>見えにくい部分を大きく映し出せるので、「今どこが悪いのか」がわかりやすくなります。説明を受けるときの不安も減らせます。</p>
        </div>
        <div class="equipment-card card">
          <h3>使う器具はすべて滅菌しています</h3>
          <p>使う器具はきちんと滅菌し、使い捨てにできるものは使い捨てにしています。見えない部分こそ、手を抜きません。</p>
        </div>
        <div class="equipment-card card">
          <h3>飛沫や粉じんを吸い取る設備</h3>
          <p>治療中に飛ぶ細かな粉じんや飛沫を吸い取ることで、院内を清潔に保ちやすくしています。</p>
        </div>
      </div>
    </div>
  </section>

  <SectionCTA
    heading="院内の雰囲気も、来院前に知っておけます。"
    text="どんな空間かを先に見ておきたい方も、お気軽にご相談ください。相談だけでも大丈夫です。"
  />
</BaseLayout>

<style>
  /* ---------- Section Titles ---------- */
  .section-title {
    font-size: 1.75rem;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .section-lead {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: 2.5rem;
  }

  /* ---------- Gallery ---------- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .gallery-item img {
    border-radius: var(--radius-md);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
  }
  .gallery-caption {
    font-weight: 600;
    font-size: 1.05rem;
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
    color: var(--color-text-heading);
  }
  .gallery-desc {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Equipment ---------- */
  .equipment-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .equipment-card h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .equipment-card p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .equipment-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
