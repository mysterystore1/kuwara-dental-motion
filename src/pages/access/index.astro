---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE } from "../../data/site";
---

<BaseLayout
  title="アクセス"
  description="湘南桑田歯科のアクセス案内。住所、最寄駅からの距離、電話番号、診療時間、地図をご案内します。"
>
  <PageHero
    title="アクセス"
    subtitle="来院前に、場所と診療時間をご確認ください"
    image="https://images.unsplash.com/photo-1562774053-701939374585?w=1400&q=80"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "アクセス" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow access-grid">
      <div class="access-card card">
        <p class="eyebrow">医院情報</p>
        <h2 class="section-title-left">{SITE.name}</h2>
        <dl class="info-dl">
          <dt>住所</dt>
          <dd>{SITE.address.full}</dd>
          <dt>電話番号</dt>
          <dd><a href={SITE.phoneHref}>{SITE.phone}</a></dd>
          <dt>最寄駅</dt>
          <dd>{SITE.address.station}</dd>
          <dt>診療時間</dt>
          <dd>
            月火水金 {SITE.hours.weekday}<br />
            土 {SITE.hours.saturday}<br />
            休診 {SITE.hours.closed}
          </dd>
        </dl>
        <div class="access-actions">
          <a href={SITE.phoneHref} class="btn-secondary">電話する</a>
          <a href="/reserve/" class="btn-primary">予約する</a>
        </div>
      </div>

      <div class="map-card">
        <div class="map-frame">
          <p>Google Maps 埋め込み予定</p>
          <span>{SITE.address.short}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-alt">
    <div class="container-narrow">
      <p class="eyebrow">ご来院のご案内</p>
      <h2 class="section-title">初めてお越しの方へ</h2>
      <div class="directions-grid">
        <article class="direction-card card">
          <span class="direction-num">01</span>
          <h3>駅からの道順</h3>
          <p>{SITE.address.station}。詳しい道順は、後日地図画像や写真付き案内に差し替えやすいよう、ここでは最小限の導線だけを置いています。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">02</span>
          <h3>来院の目安</h3>
          <p>予約時間の10分前を目安にお越しください。初診時は問診票の記入と受付があります。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">03</span>
          <h3>急いでいる場合</h3>
          <p>痛みが強い、詰め物が取れた、腫れているといった場合は、まずお電話で状況をお知らせください。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">04</span>
          <h3>お車でお越しの方</h3>
          <p>周辺駐車場の利用案内を想定しています。実際の駐車場情報は、開院後に具体の場所へ差し替えてください。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">ご予約について</p>
        <h2>予約方法もあわせて確認しておくと安心です。</h2>
        <p>WEB、LINE、お電話の3つの導線から、ご都合に合わせてお選びいただけます。</p>
      </div>
      <a href="/reserve/" class="btn-primary">ご予約・ご相談はこちら</a>
    </div>
  </section>

  <SectionCTA />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .access-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .info-dl {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 0.8rem 1rem;
    margin: 0 0 1.5rem;
  }
  .info-dl dt {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .info-dl dd {
    margin: 0;
    color: var(--color-text);
    line-height: 1.8;
  }
  .access-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .map-card {
    padding: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 100%;
    background:
      linear-gradient(180deg, rgba(43, 107, 138, 0.06), transparent 20%),
      var(--color-bg-alt);
  }
  .map-frame {
    min-height: 460px;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 0.5rem;
    color: var(--color-text-light);
    padding: 2rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    margin: 1rem;
    background: rgba(255, 255, 255, 0.55);
  }
  .map-frame p {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0;
  }
  .directions-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .direction-card {
    position: relative;
    padding-top: 3rem;
  }
  .direction-num {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary-light);
  }
  .direction-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.65rem;
  }
  .direction-card p {
    color: var(--color-text-light);
    line-height: 1.85;
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .access-grid,
    .directions-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
    .map-frame {
      min-height: 320px;
    }
  }
</style>
