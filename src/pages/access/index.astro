---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE } from "../../data/site";
import ThemedImage from "../../components/ThemedImage.astro";
import { VISUALS } from "../../data/visualAssets";

const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(SITE.address.full)}`;
---

<BaseLayout
  title="アクセス"
  description="辻堂がじゅまる歯科のアクセス案内。住所、最寄駅からの距離、電話番号、診療時間、地図をご案内します。"
>
  <PageHero
    title="アクセス"
    subtitle="JR藤沢駅南口から徒歩3分です。"
    image={VISUALS.reception.defaultSrc}
    imageWarm={VISUALS.reception.warmSrc}
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "アクセス" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow access-grid">
      <div class="access-card card">
        <p class="eyebrow">医院情報</p>
        <h2 class="section-title-left">{SITE.name}</h2>
        <dl class="info-dl">
          <dt>住所</dt>
          <dd>{SITE.address.full}</dd>
          <dt>電話番号</dt>
          <dd><a href={SITE.phoneHref}>{SITE.phone}</a></dd>
          <dt>最寄駅</dt>
          <dd>{SITE.address.station}</dd>
          <dt>診療時間</dt>
          <dd>
            月火水金 {SITE.hours.weekday}<br />
            土 {SITE.hours.saturday}<br />
            休診 {SITE.hours.closed}
          </dd>
        </dl>
        <div class="access-actions">
          <a href={SITE.phoneHref} class="btn-secondary">電話で相談する</a>
          <a href="/reserve/" class="btn-primary">WEB予約する</a>
        </div>
      </div>

      <div class="map-card">
        <div class="map-frame">
          <ThemedImage
            defaultSrc={VISUALS.routeMap.defaultSrc}
            warmSrc={VISUALS.routeMap.warmSrc}
            alt={VISUALS.routeMap.alt}
            loading="lazy"
          />
          <p>Google マップで場所を確認</p>
          <span>{SITE.address.short}</span>
          <a href={mapsUrl} class="btn-secondary" target="_blank" rel="noopener">Google マップを開く</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-alt">
    <div class="container-narrow">
      <p class="eyebrow">ご来院のご案内</p>
      <h2 class="section-title">初めてお越しの方へ</h2>
      <div class="directions-grid">
        <article class="direction-card card">
          <span class="direction-num">01</span>
          <h3>駅からの道順</h3>
          <p>{SITE.address.station}。南口を出て大通り沿いをまっすぐ進んだ場所なので、初めての方も比較的わかりやすい道順です。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">02</span>
          <h3>来院の目安</h3>
          <p>初回は10分ほど早めに来ていただけると、受付から落ち着いて始められます。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">03</span>
          <h3>急いでいる場合</h3>
          <p>痛みが強い、詰め物が取れた、腫れているときは、まずお電話ください。状況に合わせてご案内します。</p>
        </article>
        <article class="direction-card card">
          <span class="direction-num">04</span>
          <h3>お車でお越しの方</h3>
          <p>近隣の駐車場をご利用ください。場所がわかりにくいときは、お電話でもご案内します。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">ご予約について</p>
          <h2>ご予約はWEB・LINE・お電話から。</h2>
          <p>場所をご確認いただけたら、そのままご予約いただけます。相談だけでも大丈夫です。</p>
      </div>
      <a href="/reserve/" class="btn-primary">ご予約・ご相談はこちら</a>
    </div>
  </section>

  <SectionCTA
    heading="場所がわかったら、そのままご予約いただけます。"
    text="WEB、LINE、お電話から、ご都合のよい方法でご連絡ください。相談だけでも大丈夫です。"
  />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .access-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .info-dl {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 0.8rem 1rem;
    margin: 0 0 1.5rem;
  }
  .info-dl dt {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .info-dl dd {
    margin: 0;
    color: var(--color-text);
    line-height: 1.8;
  }
  .access-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .map-card {
    padding: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 100%;
    background:
      linear-gradient(180deg, rgba(43, 107, 138, 0.06), transparent 20%),
      var(--color-bg-alt);
  }
  .map-frame {
    min-height: 460px;
    display: grid;
    align-content: start;
    text-align: center;
    gap: 0.9rem;
    color: var(--color-text-light);
    padding: 2rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    margin: 1rem;
    background: rgba(255, 255, 255, 0.55);
  }
  .map-frame img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: var(--shadow-soft);
  }
  .map-frame p {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0;
  }
  .directions-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .direction-card {
    position: relative;
    padding-top: 3rem;
  }
  .direction-num {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary-light);
  }
  .direction-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.65rem;
  }
  .direction-card p {
    color: var(--color-text-light);
    line-height: 1.85;
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .access-grid,
    .directions-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
    .map-frame {
      min-height: 320px;
    }
  }
</style>
