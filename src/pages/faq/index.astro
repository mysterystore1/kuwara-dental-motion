---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE } from "../../data/site";

const faqCategories = [
  {
    title: "初診について",
    items: [
      {
        q: "初めての来院ですが、何を持っていけばいいですか？",
        a: "保険証またはマイナンバーカードをお持ちください。お薬手帳や紹介状があれば、あわせてご持参いただくと診療が進めやすくなります。",
      },
      {
        q: "初診はどれくらい時間がかかりますか？",
        a: "問診、検査、ご説明を含めて45分から1時間程度を目安にしています。症状が強い場合は、応急処置を優先することもあります。",
      },
      {
        q: "予約なしでも受診できますか？",
        a: "急な痛みなどの場合は、まずお電話でご相談ください。ご予約の方を優先していますが、できる限り状況に合わせて対応します。",
      },
    ],
  },
  {
    title: "治療について",
    items: [
      {
        q: "久しぶりの歯医者で気まずいのですが大丈夫ですか？",
        a: "もちろん大丈夫です。状態を責めることはありません。今の状況を確認したうえで、これからどう整えるかを一緒に考えます。",
      },
      {
        q: "痛みに弱いのですが相談できますか？",
        a: "はい。麻酔の打ち方や治療の進め方に配慮し、できるだけ負担を少なく進めます。不安が強い場合は、先にその旨をお伝えください。",
      },
      {
        q: "治療の説明はしてもらえますか？",
        a: "治療前に、現在の状態、治療方法の選択肢、通院の見通しをご説明します。わかりにくい点があれば、その場で遠慮なくご質問ください。",
      },
      {
        q: "その日に治療まで進みますか？",
        a: "症状やご希望によります。まずは検査とご説明を優先し、急を要する場合のみ応急処置を行うことがあります。",
      },
    ],
  },
  {
    title: "費用について",
    items: [
      {
        q: "保険診療は対応していますか？",
        a: "はい、虫歯治療、歯周病治療、抜歯などの一般的な診療は保険診療で対応できます。費用の目安は診察時にご案内します。",
      },
      {
        q: "自費診療の費用は事前にわかりますか？",
        a: "はい。ホワイトニングなどの自費診療は、費用、回数、注意点を事前にご説明します。納得いただいてから進めます。",
      },
      {
        q: "支払い方法を教えてください",
        a: "保険診療は現金、自費診療は医院の案内に沿ってお支払いいただけます。詳細は受付にてご確認ください。",
      },
    ],
  },
  {
    title: "その他",
    items: [
      {
        q: "子ども連れでも通えますか？",
        a: "はい。お子さま連れでも通院しやすいように配慮しています。小児歯科も行っていますので、ご家族でご相談ください。",
      },
      {
        q: "駐車場はありますか？",
        a: "近隣の駐車場をご案内しています。車でお越しの方は、アクセスページをご確認ください。",
      },
      {
        q: "急に歯が痛くなった場合はどうすればいいですか？",
        a: `まずはお電話（${SITE.phone}）にてご連絡ください。診療時間内であれば、できる限り状況に応じて対応します。`,
      },
    ],
  },
];
---

<BaseLayout
  title="よくあるご質問"
  description="湘南桑田歯科のよくあるご質問。初診、痛み、費用、予約、通院についてご案内します。"
>
  <PageHero
    title="よくあるご質問"
    subtitle="来院前に気になりやすいことを、先にまとめました"
    image="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=1400&q=80"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "よくあるご質問" }]} />
  </div>

  <section class="section-padding faq-intro">
    <div class="container-narrow intro-grid">
      <div>
        <p class="eyebrow">ご案内</p>
        <h2 class="section-title-left">予約、初診、治療、費用の不安を先に減らしておきます。</h2>
        <p>
          実際の来院前によくいただく質問を、できるだけ実務的にまとめました。
          迷っている段階でもご覧いただけるよう、回答は短く、必要な情報がすぐ見つかるようにしています。
        </p>
      </div>
      <div class="intro-panel card">
        <p class="panel-title">すぐ確認したい方へ</p>
        <ul class="quick-links">
          <li><a href="/first-visit/">初診の流れ</a></li>
          <li><a href="/dental-anxiety/">歯医者が怖い方へ</a></li>
          <li><a href="/reserve/">予約方法</a></li>
          <li><a href="/access/">アクセス</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow">
      {faqCategories.map((cat) => (
        <div class="faq-category">
          <p class="eyebrow">{cat.title}</p>
          <div class="faq-list">
            {cat.items.map((item) => (
              <details class="faq-item card">
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-padding bg-section">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">初診の流れ</p>
        <h2>詳しい来院の流れは、初めての方へをご覧ください。</h2>
        <p>持ち物や所要時間を先に確認しておくと、初診当日の不安を減らせます。</p>
      </div>
      <a href="/first-visit/" class="btn-primary">初めての方へ</a>
    </div>
  </section>

  <SectionCTA />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .faq-intro p {
    line-height: 1.9;
    color: var(--color-text);
  }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.5rem;
    align-items: start;
  }
  .intro-panel {
    background:
      radial-gradient(circle at top right, rgba(212, 132, 90, 0.1), transparent 40%),
      var(--color-bg);
  }
  .panel-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.8rem;
  }
  .quick-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }
  .quick-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .quick-links a::before {
    content: "→";
    color: var(--color-accent);
  }
  .faq-category {
    margin-bottom: 2.5rem;
  }
  .faq-list {
    display: grid;
    gap: 1rem;
  }
  .faq-item {
    padding: 1.25rem 1.4rem;
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding-right: 2rem;
    position: relative;
    font-weight: 700;
    line-height: 1.7;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::before {
    content: "Q. ";
    color: var(--color-primary);
  }
  .faq-item summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 0;
    color: var(--color-accent);
    font-size: 1.25rem;
  }
  .faq-item[open] summary::after {
    content: "−";
  }
  .faq-item p {
    margin: 0.9rem 0 0;
    padding-left: 1.4rem;
    color: var(--color-text-light);
    line-height: 1.9;
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .intro-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
  }
</style>
