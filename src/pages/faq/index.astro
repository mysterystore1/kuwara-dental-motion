---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionCTA from "../../components/SectionCTA.astro";
import { SITE } from "../../data/site";
import { VISUALS } from "../../data/visualAssets";

const faqCategories = [
  {
    title: "初診について",
    items: [
      {
        q: "初めての来院ですが、何を持っていけばいいですか？",
        a: "保険証またはマイナンバーカードをお持ちください。お薬手帳や紹介状があれば、あわせてご持参いただくと診療が進めやすくなります。",
      },
      {
        q: "初診はどれくらい時間がかかりますか？",
        a: "初回は1時間ほどいただいています。急かさずお話を聞く時間も含んでいます。症状が強い場合は、応急処置を優先することがあります。",
      },
      {
        q: "予約なしでも受診できますか？",
        a: "急な痛みなどの場合は、まずお電話ください。ご予約の方を優先していますが、状況に合わせてご案内します。",
      },
    ],
  },
  {
    title: "治療について",
    items: [
      {
        q: "久しぶりの歯医者で気まずいのですが大丈夫ですか？",
        a: "何年ぶりでも大丈夫です。来てくださったことがまず一番大きな一歩です。今の状態を確認して、これからどう整えていくかを一緒に考えます。",
      },
      {
        q: "痛みに弱いのですが相談できますか？",
        a: "はい。教えてください。麻酔の方法や治療の進め方を調整します。痛かったり怖くなったりしたら、その場で止めます。",
      },
      {
        q: "治療の説明はしてもらえますか？",
        a: "はい。今どこがどうなっているか、どんな治療方法があるか、通院の見通しはどうかを先にお伝えします。『今なにをしてるの？』と途中で聞いていただいても大丈夫です。",
      },
      {
        q: "その日に治療まで進みますか？",
        a: "症状やご希望によります。まずは検査とご説明を優先し、急を要する場合のみ応急処置を行うことがあります。",
      },
    ],
  },
  {
    title: "費用について",
    items: [
      {
        q: "保険診療は対応していますか？",
        a: "はい、虫歯治療、歯周病治療、抜歯などの一般的な診療は保険診療で対応できます。費用の目安は診察時にご案内します。",
      },
      {
        q: "自費診療の費用は事前にわかりますか？",
        a: "はい。ホワイトニングなどの自費診療は、費用、回数、注意点を事前にご説明します。納得いただいてから進めます。",
      },
      {
        q: "支払い方法を教えてください",
        a: "保険診療は現金、自費診療は医院の案内に沿ってお支払いいただけます。詳細は受付にてご確認ください。",
      },
    ],
  },
  {
    title: "その他",
    items: [
      {
        q: "子ども連れでも通えますか？",
        a: "はい。お子さま連れで来ていただけます。小児歯科も行っているので、ご家族一緒の通院や仕上げみがきのご相談もしていただけます。",
      },
      {
        q: "駐車場はありますか？",
        a: "近隣の駐車場をご案内しています。お車でお越しの方は、アクセスページもあわせてご確認ください。",
      },
      {
        q: "急に歯が痛くなった場合はどうすればいいですか？",
        a: `まずはお電話（${SITE.phone}）にてご連絡ください。診療時間内であれば、できる限り状況に応じて対応します。`,
      },
    ],
  },
];
---

<BaseLayout
  title="よくあるご質問"
  description="辻堂がじゅまる歯科のよくあるご質問。初診、痛み、費用、予約、通院について、来院前に気になりやすい点をまとめています。"
>
  <PageHero
    title="よくあるご質問"
    subtitle="気になることを、先に確認できるようにまとめました"
    image={VISUALS.consultation.defaultSrc}
    imageWarm={VISUALS.consultation.warmSrc}
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "よくあるご質問" }]} />
  </div>

  <section class="section-padding faq-intro">
    <div class="container-narrow intro-grid">
      <div>
        <p class="eyebrow">ご案内</p>
        <h2 class="section-title-left">よく聞かれる質問をまとめました。</h2>
        <p>
          予約、初診、痛み、費用。
          来院前に聞かれることを、ひとつずつ確認しやすいようにまとめています。
        </p>
      </div>
      <div class="intro-panel card">
        <p class="panel-title">すぐ確認したい方へ</p>
        <ul class="quick-links">
          <li><a href="/first-visit/">初診の流れ</a></li>
          <li><a href="/dental-anxiety/">歯医者が怖い方へ</a></li>
          <li><a href="/reserve/">予約方法</a></li>
          <li><a href="/access/">アクセス</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow">
      {faqCategories.map((cat) => (
        <div class="faq-category">
          <p class="eyebrow">{cat.title}</p>
          <div class="faq-list">
            {cat.items.map((item) => (
              <details class="faq-item card">
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-padding bg-section">
    <div class="container-narrow cta-linkbox">
      <div>
        <p class="eyebrow">初診の流れ</p>
        <h2>初診の流れも、先に確認できます。</h2>
        <p>持ち物や当日の流れは、「初めての方へ」にまとめています。</p>
      </div>
      <a href="/first-visit/" class="btn-primary">初めての方へ</a>
    </div>
  </section>

  <SectionCTA
    heading="他にも気になることがあれば、お電話でもどうぞ。"
    text="WEBやLINEだけでなく、お電話でのご相談にも対応しています。迷っている段階でも大丈夫です。"
  />
</BaseLayout>

<style>
  .eyebrow {
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    font-size: 1.8rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .faq-intro p {
    line-height: 1.9;
    color: var(--color-text);
  }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.5rem;
    align-items: start;
  }
  .intro-panel {
    background:
      radial-gradient(circle at top right, rgba(212, 132, 90, 0.1), transparent 40%),
      var(--color-bg);
  }
  .panel-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.8rem;
  }
  .quick-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }
  .quick-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .quick-links a::before {
    content: "→";
    color: var(--color-accent);
  }
  .faq-category {
    margin-bottom: 2.5rem;
  }
  .faq-list {
    display: grid;
    gap: 1rem;
  }
  .faq-item {
    padding: 1.25rem 1.4rem;
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding-right: 2rem;
    position: relative;
    font-weight: 700;
    line-height: 1.7;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::before {
    content: "Q. ";
    color: var(--color-primary);
  }
  .faq-item summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 0;
    color: var(--color-accent);
    font-size: 1.25rem;
  }
  .faq-item[open] summary::after {
    content: "−";
  }
  .faq-item p {
    margin: 0.9rem 0 0;
    padding-left: 1.4rem;
    color: var(--color-text-light);
    line-height: 1.9;
  }
  .cta-linkbox {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }
  .cta-linkbox h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }
  .cta-linkbox p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  @media (max-width: 900px) {
    .intro-grid,
    .cta-linkbox {
      grid-template-columns: 1fr;
      display: grid;
    }
  }
</style>
