---
import ThemedImage from "./ThemedImage.astro";

interface Slide {
  defaultSrc: string;
  warmSrc?: string;
  alt: string;
  label: string;
  title: string;
  description: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="hero-carousel" data-carousel data-carousel-interval="5200">
  <div class="hero-carousel__media">
    {slides.map((slide, index) => (
      <figure class:list={["hero-carousel__slide", index === 0 && "is-active"]} data-carousel-slide>
        <ThemedImage
          defaultSrc={slide.defaultSrc}
          warmSrc={slide.warmSrc}
          alt={slide.alt}
          class="hero-carousel__image"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </figure>
    ))}
  </div>
</div>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initCarousel(root) {
    const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
    const interval = Number(root.dataset.carouselInterval || 5200);

    if (slides.length < 2) return;

    let index = 0;
    let timer = null;

    const setIndex = (nextIndex) => {
      index = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle("is-active", slideIndex === index);
      });
    };

    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    const start = () => {
      if (reduceMotion) return;
      stop();
      timer = window.setInterval(() => setIndex(index + 1), interval);
    };

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  }

  document.querySelectorAll("[data-carousel]").forEach((root) => initCarousel(root));
</script>

<style>
  .hero-carousel {
    position: absolute;
    inset: 0;
  }

  .hero-carousel__media {
    position: absolute;
    inset: 0 0 13% 6%;
    isolation: isolate;
  }

  .hero-carousel__media::before {
    content: "";
    position: absolute;
    inset: 8% auto 10% -8%;
    width: 24%;
    border-radius: 48% 52% 42% 58% / 50% 44% 56% 50%;
    background: color-mix(in srgb, var(--color-paper) 90%, white 10%);
    box-shadow: 0 14px 28px rgba(27, 53, 82, 0.04);
    z-index: 0;
  }

  .hero-carousel__media::after {
    content: "";
    position: absolute;
    inset: auto -2% -6% auto;
    width: 28%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-paper) 92%, white 8%);
    filter: blur(2px);
    opacity: 0.92;
    z-index: 2;
    pointer-events: none;
  }

  .hero-carousel__slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: translateX(1.2rem) scale(0.992);
    transition: opacity 1.05s cubic-bezier(0.16, 1, 0.3, 1), transform 1.05s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    isolation: isolate;
  }

  .hero-carousel__slide.is-active {
    opacity: 1;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .hero-carousel__slide::before {
    content: "";
    position: absolute;
    inset: 12% auto 14% -10%;
    width: 26%;
    border-radius: 46% 54% 60% 40% / 56% 42% 58% 44%;
    background: color-mix(in srgb, var(--color-paper) 88%, white 12%);
    filter: blur(4px);
    opacity: 0.96;
    z-index: 2;
    pointer-events: none;
  }

  .hero-carousel__slide::after {
    content: "";
    position: absolute;
    inset: auto 6% -3% auto;
    width: 19%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-surface) 88%, white 12%);
    filter: blur(8px);
    opacity: 0.72;
    z-index: 2;
    pointer-events: none;
  }

  .hero-carousel__image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2.25rem;
    box-shadow: var(--shadow-float);
    translate: 0 0;
    will-change: translate;
  }

  .hero-carousel__slide.is-active .hero-carousel__image {
    animation: hero-carousel-image-float 14s ease-in-out infinite;
  }

  :global(html[data-theme="warm"]) .hero-carousel__media {
    inset: 0 1% 0 4%;
  }

  :global(html[data-theme="warm"]) .hero-carousel__media::before {
    background: color-mix(in srgb, var(--color-paper) 90%, rgba(255, 232, 214, 1) 10%);
  }

  :global(html[data-theme="warm"]) .hero-carousel__media::after {
    background: color-mix(in srgb, var(--color-paper) 90%, rgba(247, 241, 232, 1) 10%);
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide {
    transform: translateX(0.9rem) translateY(0.15rem) scale(0.988) rotate(0.35deg);
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide.is-active {
    transform: translateX(0) translateY(0) scale(1) rotate(-0.2deg);
  }

  :global(html[data-theme="warm"]) .hero-carousel__image {
    border-radius: 2.4rem;
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide::before {
    background: color-mix(in srgb, var(--color-paper) 86%, rgba(255, 233, 212, 1) 14%);
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide::after {
    background: color-mix(in srgb, var(--color-surface) 86%, rgba(255, 228, 204, 1) 14%);
  }

  @media (max-width: 900px) {
    .hero-carousel__media {
      inset: 2% 2% 8% 8%;
    }

    .hero-carousel__media::before {
      inset: 10% auto 12% -6%;
      width: 20%;
    }

    .hero-carousel__slide::before {
      inset: 14% auto 16% -6%;
      width: 19%;
    }
  }

  @media (max-width: 900px) {
    :global(html[data-theme="warm"]) .hero-carousel__media {
      inset: 2% 2% 8% 7%;
    }
  }

  @media (max-width: 640px) {
    .hero-carousel__media {
      inset: 2% 1% 10% 7%;
    }

    .hero-carousel__media::after,
    .hero-carousel__slide::after {
      width: 24%;
    }
  }

  @media (max-width: 640px) {
    :global(html[data-theme="warm"]) .hero-carousel__media {
      inset: 2% 1% 10% 6%;
    }
  }

  @keyframes hero-carousel-image-float {
    0%,
    100% {
      translate: 0 0;
    }

    50% {
      translate: 0 -0.28rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-carousel__slide {
      transition: none;
    }

    .hero-carousel__slide.is-active .hero-carousel__image {
      animation: none !important;
      translate: 0 0 !important;
    }
  }
</style>
