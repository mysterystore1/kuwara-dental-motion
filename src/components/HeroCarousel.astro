---
import ThemedImage from "./ThemedImage.astro";

interface Slide {
  defaultSrc: string;
  warmSrc?: string;
  alt: string;
  label: string;
  title: string;
  description: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="hero-carousel" data-carousel data-carousel-interval="5200">
  <div class="hero-carousel__media">
    {slides.map((slide, index) => (
      <figure class:list={["hero-carousel__slide", index === 0 && "is-active"]} data-carousel-slide>
        <ThemedImage
          defaultSrc={slide.defaultSrc}
          warmSrc={slide.warmSrc}
          alt={slide.alt}
          class="hero-carousel__image"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </figure>
    ))}
  </div>

  <div class="hero-carousel__hud" aria-label="ヒーロー画像の切り替え">
    <div class="hero-carousel__controls">
      <button type="button" class="hero-carousel__arrow" data-carousel-prev aria-label="前の画像へ">
        <span aria-hidden="true">←</span>
      </button>
      <button type="button" class="hero-carousel__arrow" data-carousel-next aria-label="次の画像へ">
        <span aria-hidden="true">→</span>
      </button>
    </div>

    <div class="hero-carousel__dots" role="tablist" aria-label="ヒーロー画像の切り替え">
      {slides.map((slide, index) => (
        <button
          type="button"
          class:list={["hero-carousel__dot", index === 0 && "is-active"]}
          data-carousel-dot
          aria-label={`${index + 1}枚目: ${slide.title}`}
          aria-selected={index === 0 ? "true" : "false"}
        ></button>
      ))}
    </div>
  </div>
</div>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initCarousel(root) {
    const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-carousel-dot]"));
    const prev = root.querySelector("[data-carousel-prev]");
    const next = root.querySelector("[data-carousel-next]");
    const interval = Number(root.dataset.carouselInterval || 5200);

    if (slides.length < 2) return;

    let index = 0;
    let timer = null;

    const setIndex = (nextIndex) => {
      index = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle("is-active", slideIndex === index);
      });

      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === index;
        dot.classList.toggle("is-active", active);
        dot.setAttribute("aria-selected", active ? "true" : "false");
      });
    };

    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    const start = () => {
      if (reduceMotion) return;
      stop();
      timer = window.setInterval(() => setIndex(index + 1), interval);
    };

    prev?.addEventListener("click", () => {
      setIndex(index - 1);
      start();
    });

    next?.addEventListener("click", () => {
      setIndex(index + 1);
      start();
    });

    dots.forEach((dot, dotIndex) => {
      dot.addEventListener("click", () => {
        setIndex(dotIndex);
        start();
      });
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  }

  document.querySelectorAll("[data-carousel]").forEach((root) => initCarousel(root));
</script>

<style>
  .hero-carousel {
    position: absolute;
    inset: 0;
  }

  .hero-carousel__media {
    position: absolute;
    inset: 0 0 13% 6%;
  }

  .hero-carousel__slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: translateX(1.2rem) scale(0.992);
    transition: opacity 1.05s cubic-bezier(0.16, 1, 0.3, 1), transform 1.05s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hero-carousel__slide.is-active {
    opacity: 1;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .hero-carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2.25rem;
    box-shadow: var(--shadow-float);
    translate: 0 0;
    will-change: translate;
  }

  .hero-carousel__slide.is-active .hero-carousel__image {
    animation: hero-carousel-image-float 14s ease-in-out infinite;
  }

  .hero-carousel__hud {
    position: absolute;
    left: 1.25rem;
    right: 1.25rem;
    bottom: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    padding: 0.55rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(125, 173, 200, 0.14);
    box-shadow: 0 12px 30px rgba(27, 53, 82, 0.08);
    backdrop-filter: blur(10px);
  }

  .hero-carousel__controls,
  .hero-carousel__dots {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .hero-carousel__arrow,
  .hero-carousel__dot {
    border: 0;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease, opacity 0.2s ease;
  }

  .hero-carousel__arrow {
    width: 2.3rem;
    height: 2.3rem;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(125, 173, 200, 0.12);
    color: var(--color-primary-dark);
  }

  .hero-carousel__arrow:hover,
  .hero-carousel__dot:hover {
    transform: translateY(-1px);
  }

  .hero-carousel__dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(125, 173, 200, 0.22);
  }

  .hero-carousel__dot.is-active {
    width: 2rem;
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary-dark));
  }

  :global(html[data-theme="warm"]) .hero-carousel__media {
    inset: 0 1% 14% 4%;
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide {
    transform: translateX(0.9rem) translateY(0.15rem) scale(0.988) rotate(0.35deg);
  }

  :global(html[data-theme="warm"]) .hero-carousel__slide.is-active {
    transform: translateX(0) translateY(0) scale(1) rotate(-0.2deg);
  }

  :global(html[data-theme="warm"]) .hero-carousel__image {
    border-radius: 2.4rem;
  }

  :global(html[data-theme="warm"]) .hero-carousel__hud {
    background: rgba(255, 249, 242, 0.84);
    border-color: rgba(211, 159, 116, 0.2);
    box-shadow: 0 14px 32px rgba(111, 92, 62, 0.1);
  }

  :global(html[data-theme="warm"]) .hero-carousel__arrow {
    background: rgba(229, 138, 82, 0.15);
    color: var(--color-accent);
  }

  :global(html[data-theme="warm"]) .hero-carousel__dot {
    background: rgba(229, 138, 82, 0.22);
  }

  @media (max-width: 900px) {
    .hero-carousel__media {
      inset: 2% 2% 18% 8%;
    }

    .hero-carousel__hud {
      left: 1rem;
      right: 1rem;
    }
  }

  @media (max-width: 900px) {
    :global(html[data-theme="warm"]) .hero-carousel__media {
      inset: 2% 2% 18% 7%;
    }
  }

  @media (max-width: 640px) {
    .hero-carousel__media {
      inset: 2% 1% 24% 7%;
    }

    .hero-carousel__hud {
      left: 0.7rem;
      right: 0.7rem;
      bottom: 0.6rem;
      padding: 0.45rem 0.6rem;
    }
  }

  @media (max-width: 640px) {
    :global(html[data-theme="warm"]) .hero-carousel__media {
      inset: 2% 1% 24% 6%;
    }
  }

  @keyframes hero-carousel-image-float {
    0%,
    100% {
      translate: 0 0;
    }

    50% {
      translate: 0 -0.28rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-carousel__slide {
      transition: none;
    }

    .hero-carousel__slide.is-active .hero-carousel__image {
      animation: none !important;
      translate: 0 0 !important;
    }
  }
</style>
