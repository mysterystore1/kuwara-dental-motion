---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="パンくずリスト">
  <ol>
    <li><a href="/">トップ</a></li>
    {items.map((item, i) => (
      <li>
        {item.href && i < items.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb {
    padding: 1rem 0;
  }
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
  .breadcrumb li:not(:last-child)::after {
    content: ">";
    margin-left: 0.4rem;
  }
  .breadcrumb a {
    color: var(--color-text-light);
  }
  .breadcrumb a:hover {
    color: var(--color-primary);
  }
  .breadcrumb [aria-current] {
    color: var(--color-text);
  }
</style>
