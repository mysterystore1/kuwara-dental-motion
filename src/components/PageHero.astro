---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  label?: string;
}

const {
  title,
  subtitle,
  image,
  label = "ご案内",
} = Astro.props;
---

<section class="page-hero">
  <div class="container-narrow page-hero__inner">
    <div class="page-hero__copy">
      <p class="section-kicker">{label}</p>
      <h1 class="page-hero__title">{title}</h1>
      {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
    </div>

    {image && (
      <div class="page-hero__visual">
        <div class="page-hero__shape"></div>
        <img src={image} alt={title} loading="eager" />
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(2.8rem, 5vw, 5rem) 0 clamp(2.2rem, 4vw, 4.2rem);
    background:
      radial-gradient(circle at left top, rgba(125, 173, 200, 0.18), transparent 40%),
      radial-gradient(circle at right 10%, rgba(219, 139, 87, 0.12), transparent 28%),
      linear-gradient(180deg, #fffaf4 0%, #f4f9fd 100%);
  }

  .page-hero::after {
    content: "";
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: -4.2rem;
    height: 8rem;
    background: var(--color-paper);
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }

  .page-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 0.92fr;
    gap: 2rem;
    align-items: center;
  }

  .page-hero__copy {
    max-width: 42rem;
  }

  .page-hero__title {
    margin: 0.22rem 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .page-hero__subtitle {
    margin: 0;
    max-width: 34rem;
    color: var(--color-text-soft);
    font-size: 1.02rem;
  }

  .page-hero__visual {
    position: relative;
    min-height: 21rem;
  }

  .page-hero__shape {
    position: absolute;
    inset: 8% 6% auto auto;
    width: 78%;
    height: 80%;
    background: rgba(125, 173, 200, 0.14);
    border-radius: 48% 52% 58% 42% / 42% 46% 54% 58%;
  }

  .page-hero__visual img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 38% 62% 42% 58% / 48% 44% 56% 52%;
    box-shadow: var(--shadow-float);
  }

  @media (max-width: 860px) {
    .page-hero__inner {
      grid-template-columns: 1fr;
    }

    .page-hero__visual {
      min-height: 16rem;
      max-width: 34rem;
      width: 100%;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
