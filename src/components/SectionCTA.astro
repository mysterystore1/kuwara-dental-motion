---
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "まずはお気軽にご相談ください",
  text = "歯医者が久しぶりの方も、怖いと感じている方も、まずはお話を聞くところから始めます。ご予約は WEB・LINE・お電話から承っています。",
} = Astro.props;
---

<section class="cta-section section-padding">
  <div class="container-narrow cta-inner">
    <h2 class="cta-heading">{heading}</h2>
    <p class="cta-text">{text}</p>
    <div class="cta-buttons">
      <a href="/reserve/" class="btn-primary">ご予約・ご相談はこちら</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--color-primary);
    color: #fff;
    text-align: center;
  }
  .cta-heading {
    font-size: 1.75rem;
    color: #fff;
    margin-bottom: 1rem;
  }
  .cta-text {
    max-width: 600px;
    margin: 0 auto 2rem;
    opacity: 0.92;
    line-height: 1.8;
  }
  .cta-buttons .btn-primary {
    background: #fff;
    color: var(--color-primary);
    font-size: 1.05rem;
    padding: 1rem 2.5rem;
  }
  .cta-buttons .btn-primary:hover {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
</style>
