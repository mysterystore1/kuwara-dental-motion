---
import { SITE } from "../data/site";

interface Props {
  heading?: string;
  text?: string;
  note?: string;
  items?: string[];
  secondaryLabel?: string;
  secondaryHref?: string;
  tertiaryLabel?: string;
  tertiaryHref?: string;
  showPhoneNumber?: boolean;
}

const {
  heading = "まずは、お気軽にご相談ください。",
  text = "治療するかどうかは、来てから一緒に考えましょう。",
  note = "",
  items = [],
  secondaryLabel = "LINEで相談",
  secondaryHref = SITE.reserve.line,
  tertiaryLabel = "",
  tertiaryHref = "",
  showPhoneNumber = true,
} = Astro.props;
---

<section class="cta-section section-padding">
  <div class="container-narrow">
    <div class="cta-shell" data-reveal>
      <div class="cta-copy">
        <p class="section-kicker">ご予約・ご相談</p>
        <h2 class="cta-heading">{heading}</h2>
        <p class="cta-text">{text}</p>
        {note && <p class="cta-note">{note}</p>}
        {items.length > 0 && (
          <ul class="cta-list">
            {items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </div>

      <div class="cta-actions">
        <a href="/reserve/" class="btn-primary">WEB予約する</a>
        <a
          href={secondaryHref}
          class="btn-secondary"
          target={secondaryHref.startsWith("http") ? "_blank" : undefined}
          rel={secondaryHref.startsWith("http") ? "noopener" : undefined}
        >
          {secondaryLabel}
        </a>
        {tertiaryLabel && tertiaryHref && (
          <a href={tertiaryHref} class="btn-secondary cta-actions__tertiary">{tertiaryLabel}</a>
        )}
        {showPhoneNumber && <a href={SITE.phoneHref} class="cta-phone">{SITE.phone}</a>}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    overflow: hidden;
  }

  .cta-shell {
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 0.95fr;
    gap: 2rem;
    align-items: center;
    padding: clamp(2rem, 4vw, 3.2rem);
    border: 1px solid rgba(125, 173, 200, 0.18);
    border-radius: 2.4rem;
    background:
      radial-gradient(circle at top right, rgba(219, 139, 87, 0.16), transparent 28%),
      linear-gradient(135deg, rgba(255,255,255,0.96), rgba(242, 248, 252, 0.96));
    box-shadow: var(--shadow-soft);
  }

  .cta-shell::before,
  .cta-shell::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    background: rgba(125, 173, 200, 0.08);
    pointer-events: none;
  }

  .cta-shell::before {
    inset: auto auto -3rem -2rem;
    width: 9rem;
    height: 9rem;
  }

  .cta-shell::after {
    inset: -2rem 8% auto auto;
    width: 7rem;
    height: 7rem;
    background: rgba(219, 139, 87, 0.1);
  }

  .cta-copy {
    position: relative;
    z-index: 1;
  }

  .cta-heading {
    margin: 0.2rem 0 0.8rem;
    font-size: clamp(1.85rem, 3vw, 2.6rem);
    line-height: 1.35;
  }

  .cta-text {
    margin: 0;
    color: var(--color-text-soft);
    max-width: 40rem;
  }

  .cta-note {
    margin-top: 0.9rem;
    color: var(--color-heading);
    font-weight: 700;
  }

  .cta-list {
    display: grid;
    gap: 0.55rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--color-text-soft);
  }

  .cta-list li {
    position: relative;
    padding-left: 1.2rem;
  }

  .cta-list li::before {
    content: "";
    position: absolute;
    top: 0.82rem;
    left: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .cta-actions {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.85rem;
    justify-items: start;
  }

  .cta-phone {
    color: var(--color-ink);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .cta-actions__tertiary {
    background: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 800px) {
    .cta-shell {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      justify-items: stretch;
    }

    .cta-actions .btn-primary,
    .cta-actions .btn-secondary {
      justify-content: center;
    }
  }
</style>
