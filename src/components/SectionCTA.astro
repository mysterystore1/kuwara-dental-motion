---
import { SITE } from "../data/site";

interface Props {
  heading?: string;
  text?: string;
  note?: string;
  items?: string[];
  secondaryLabel?: string;
  secondaryHref?: string;
  tertiaryLabel?: string;
  tertiaryHref?: string;
  showPhoneNumber?: boolean;
}

const {
  heading = "まずは、お気軽にご相談ください。",
  text = "治療するかどうかは、来てから一緒に考えましょう。",
  note = "",
  items = [],
  secondaryLabel = "LINEで相談",
  secondaryHref = SITE.reserve.line,
  tertiaryLabel = "",
  tertiaryHref = "",
  showPhoneNumber = true,
} = Astro.props;
---

<section class="cta-section section-padding">
  <div class="container-narrow">
    <div class="cta-shell" data-reveal>
      <div class="cta-copy">
        <p class="section-kicker">ご予約・ご相談</p>
        <h2 class="cta-heading">{heading}</h2>
        <p class="cta-text">{text}</p>
        {note && <p class="cta-note">{note}</p>}
        {items.length > 0 && (
          <ul class="cta-list">
            {items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </div>

      <div class="cta-actions">
        <a href="/reserve/" class="btn-primary">WEB予約する</a>
        <a
          href={secondaryHref}
          class="btn-secondary"
          target={secondaryHref.startsWith("http") ? "_blank" : undefined}
          rel={secondaryHref.startsWith("http") ? "noopener" : undefined}
        >
          {secondaryLabel}
        </a>
        {tertiaryLabel && tertiaryHref && (
          <a href={tertiaryHref} class="btn-secondary cta-actions__tertiary">{tertiaryLabel}</a>
        )}
        {showPhoneNumber && <a href={SITE.phoneHref} class="cta-phone">{SITE.phone}</a>}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: clamp(2.8rem, 5vw, 4.2rem);
    padding-bottom: clamp(2.8rem, 5vw, 4.2rem);
  }

  .cta-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem 3rem;
    align-items: start;
    padding: 2rem 0;
    border-top: 1px solid rgba(125, 173, 200, 0.18);
    border-bottom: 1px solid rgba(125, 173, 200, 0.18);
  }

  .cta-copy {
    max-width: 42rem;
  }

  .cta-heading {
    margin: 0.2rem 0 0.7rem;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.28;
  }

  .cta-text {
    margin: 0;
    color: var(--color-text-soft);
  }

  .cta-note {
    margin-top: 1rem;
    color: var(--color-heading);
    font-weight: 700;
  }

  .cta-list {
    display: grid;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--color-text-soft);
  }

  .cta-list li {
    position: relative;
    padding-left: 1rem;
  }

  .cta-list li::before {
    content: "";
    position: absolute;
    top: 0.78rem;
    left: 0;
    width: 0.36rem;
    height: 0.36rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .cta-actions {
    display: grid;
    gap: 0.85rem;
    justify-items: start;
    min-width: 13rem;
  }

  .cta-phone {
    color: var(--color-ink);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .cta-actions__tertiary {
    background: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 800px) {
    .cta-shell {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.75rem 0;
    }

    .cta-actions {
      justify-items: stretch;
    }

    .cta-actions .btn-primary,
    .cta-actions .btn-secondary {
      justify-content: center;
    }
  }
</style>
