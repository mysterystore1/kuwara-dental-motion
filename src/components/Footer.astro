---
import { SITE, NAV_ITEMS } from "../data/site";
---

<footer class="site-footer">
  <div class="container-narrow">
    <div class="footer-grid">
      <!-- Clinic info -->
      <div class="footer-info">
        <p class="footer-logo">{SITE.name}</p>
        <p class="footer-tagline">{SITE.tagline}</p>
        <address class="footer-address">
          <p>{SITE.address.full}</p>
          <p>{SITE.address.station}</p>
          <p><a href={SITE.phoneHref}>{SITE.phone}</a></p>
        </address>
      </div>

      <!-- Hours -->
      <div class="footer-hours">
        <p class="footer-heading">診療時間</p>
        <table class="hours-table">
          <tbody>
            <tr><td>月・火・水・金</td><td>{SITE.hours.weekday}</td></tr>
            <tr><td>土</td><td>{SITE.hours.saturday}</td></tr>
            <tr><td>休診</td><td>{SITE.hours.closed}</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Links -->
      <div class="footer-links">
        <p class="footer-heading">サイトマップ</p>
        <ul>
          <li><a href="/">トップページ</a></li>
          <li><a href="/first-visit/">初めての方へ</a></li>
          <li><a href="/dental-anxiety/">歯医者が怖い方へ</a></li>
          {NAV_ITEMS.filter((i) => i.children).flatMap((group) =>
            group.children!.map((child) => (
              <li><a href={child.href}>{child.label}</a></li>
            ))
          )}
          <li><a href="/faq/">FAQ</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {SITE.name} All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text-heading);
    color: #ccc;
    padding: 3.5rem 1.5rem 1.5rem;
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 2.5rem;
  }
  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .footer-tagline {
    color: var(--color-primary-light);
    font-size: 0.8rem;
    margin-bottom: 1rem;
  }
  .footer-address { font-style: normal; }
  .footer-address a { color: #ccc; }
  .footer-address a:hover { color: #fff; }

  .footer-heading {
    color: #fff;
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }
  .hours-table td {
    padding: 0.2rem 0;
  }
  .hours-table td:first-child {
    padding-right: 1rem;
    white-space: nowrap;
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    columns: 2;
    column-gap: 1rem;
  }
  .footer-links a {
    color: #ccc;
    display: inline-block;
    padding: 0.15rem 0;
  }
  .footer-links a:hover { color: #fff; }

  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.15);
    text-align: center;
    font-size: 0.75rem;
    color: #999;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-links ul { columns: 1; }
  }
</style>
