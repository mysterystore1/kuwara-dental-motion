---
import { SITE, NAV_ITEMS } from "../data/site";

const withBase = (src: string) => {
  const base = import.meta.env.BASE_URL || "/";
  return src.startsWith("/") ? `${base.replace(/\/$/, "")}${src}` : src;
};
---

<header class="site-header">
  <div class="header-utility">
    <div class="container-narrow header-utility__inner">
      <p class="header-utility__copy">怖い方も、まずはお話から。</p>
      <div class="header-utility__meta">
        <span>{SITE.address.station}</span>
        <a href={SITE.phoneHref}>{SITE.phone}</a>
      </div>
    </div>
  </div>

  <nav class="header-main">
    <div class="container-narrow header-main__inner">
      <a href="/" class="site-brand" aria-label={`${SITE.name} ホーム`}>
        <img
          src={withBase("/images/common/brand/gajumaru-lockup-horizontal.svg")}
          alt={`${SITE.name} ロゴ`}
          class="site-brand__logo"
          loading="eager"
          decoding="async"
        />
      </a>

      <button class="hamburger" type="button" aria-label="メニューを開く" aria-expanded="false" aria-controls="global-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-shell">
        <ul id="global-nav" class="nav-list">
          {NAV_ITEMS.map((item) => (
            <li class:list={["nav-item", item.children && "has-dropdown"]}>
              <a href={item.href} class="nav-link">{item.label}</a>
              {item.children && (
                <ul class="dropdown">
                  {item.children.map((child) => (
                    <li><a href={child.href}>{child.label}</a></li>
                  ))}
                </ul>
              )}
            </li>
          ))}
          <li class="nav-actions">
            <a href="/reserve/" class="btn-primary">WEB予約</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 120;
    backdrop-filter: blur(14px);
    background: rgba(255, 251, 246, 0.78);
    border-bottom: 1px solid rgba(125, 173, 200, 0.16);
  }

  :global(html[data-theme="warm"]) .site-header {
    background: rgba(255, 246, 236, 0.9);
    border-bottom-color: rgba(211, 159, 116, 0.2);
  }

  .header-utility {
    border-bottom: 1px solid rgba(125, 173, 200, 0.14);
    background:
      radial-gradient(circle at left top, rgba(125, 173, 200, 0.12), transparent 42%),
      linear-gradient(180deg, rgba(255,255,255,0.85), rgba(255,255,255,0.65));
  }

  :global(html[data-theme="warm"]) .header-utility {
    background:
      radial-gradient(circle at left top, rgba(229, 138, 82, 0.14), transparent 40%),
      linear-gradient(180deg, rgba(255, 249, 241, 0.92), rgba(255, 243, 233, 0.78));
    border-bottom-color: rgba(211, 159, 116, 0.18);
  }

  .header-utility__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    min-height: 2.5rem;
    font-size: 0.78rem;
    color: var(--color-text-soft);
  }

  .header-utility__copy {
    margin: 0;
  }

  .header-utility__meta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    white-space: nowrap;
  }

  .header-utility__meta a {
    color: var(--color-ink);
    font-weight: 600;
  }

  .header-main {
    padding: 0.95rem 0 1rem;
  }

  .header-main__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    min-width: 0;
  }

  .site-brand__logo {
    display: block;
    width: min(100%, 21rem);
    height: auto;
  }

  .nav-shell {
    flex: 1 1 auto;
    display: flex;
    justify-content: flex-end;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.22rem;
    list-style: none;
    margin: 0;
    padding: 0.38rem;
    border: 1px solid rgba(125, 173, 200, 0.18);
    border-radius: 999px;
    background: rgba(255,255,255,0.92);
    box-shadow: 0 16px 36px rgba(27, 53, 82, 0.06);
  }

  :global(html[data-theme="warm"]) .nav-list {
    background: rgba(255, 250, 244, 0.95);
    border-color: rgba(211, 159, 116, 0.22);
    box-shadow: 0 18px 40px rgba(111, 92, 62, 0.09);
  }

  .nav-item {
    position: relative;
  }

  @media (min-width: 1025px) {
    .nav-item::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: max(100%, 14rem);
      height: 1rem;
    }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.72rem 0.95rem;
    border-radius: 999px;
    color: var(--color-ink);
    font-size: 0.92rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: rgba(125, 173, 200, 0.1);
    color: var(--color-primary-dark);
  }

  :global(html[data-theme="warm"]) .nav-link:hover {
    background: rgba(229, 138, 82, 0.1);
    color: var(--color-accent);
  }

  .dropdown {
    display: none;
    position: absolute;
    inset: calc(100% + 0.2rem) auto auto 0;
    min-width: 13.5rem;
    list-style: none;
    margin: 0;
    padding: 0.65rem;
    border-radius: 1.2rem;
    background: rgba(255,255,255,0.98);
    border: 1px solid rgba(125, 173, 200, 0.18);
    box-shadow: 0 22px 42px rgba(27, 53, 82, 0.12);
  }

  :global(html[data-theme="warm"]) .dropdown {
    background: rgba(255, 250, 244, 0.98);
    border-color: rgba(211, 159, 116, 0.22);
    box-shadow: 0 22px 42px rgba(111, 92, 62, 0.12);
  }

  .dropdown a {
    display: block;
    padding: 0.72rem 0.9rem;
    border-radius: 0.9rem;
    color: var(--color-ink);
    font-size: 0.9rem;
  }

  .dropdown a:hover {
    background: rgba(125, 173, 200, 0.1);
  }

  :global(html[data-theme="warm"]) .dropdown a:hover {
    background: rgba(229, 138, 82, 0.08);
  }

  .has-dropdown:hover .dropdown {
    display: block;
  }

  .nav-actions {
    padding-left: 0.24rem;
  }

  .hamburger {
    display: none;
    width: 2.95rem;
    height: 2.95rem;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.32rem;
    border: 1px solid rgba(125, 173, 200, 0.18);
    border-radius: 999px;
    background: rgba(255,255,255,0.92);
    box-shadow: 0 16px 36px rgba(27, 53, 82, 0.06);
    color: var(--color-ink);
  }

  :global(html[data-theme="warm"]) .hamburger {
    background: rgba(255, 250, 244, 0.95);
    border-color: rgba(211, 159, 116, 0.22);
    box-shadow: 0 16px 36px rgba(111, 92, 62, 0.08);
  }

  .hamburger span {
    width: 1.1rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  @media (max-width: 1024px) {
    .header-utility__copy {
      display: none;
    }

    .hamburger {
      display: inline-flex;
    }

    .nav-shell {
      position: absolute;
      top: calc(100% + 0.35rem);
      left: 1rem;
      right: 1rem;
      display: none;
    }

    .nav-shell.open {
      display: block;
    }

    .nav-list {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      border-radius: 1.8rem;
      padding: 0.85rem;
      gap: 0.2rem;
    }

    .nav-link {
      padding: 0.95rem 1rem;
      justify-content: space-between;
    }

    .dropdown {
      position: static;
      min-width: 0;
      margin-top: 0.2rem;
      padding: 0.35rem 0 0.55rem 0.6rem;
      box-shadow: none;
      border: 0;
      background: transparent;
    }

    .has-dropdown:hover .dropdown {
      display: none;
    }

    .has-dropdown.open .dropdown {
      display: block;
    }

    .nav-actions {
      padding-top: 0.55rem;
    }

    .nav-actions .btn-primary {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 720px) {
    .header-utility__meta {
      gap: 0.7rem;
      font-size: 0.72rem;
    }

    .header-main__inner {
      gap: 1rem;
    }

    .site-brand__logo {
      width: min(100%, 16rem);
    }
  }
</style>

<script>
  const hamburger = document.querySelector(".hamburger");
  const navShell = document.querySelector(".nav-shell");
  const navItems = document.querySelectorAll(".has-dropdown > .nav-link");

  hamburger?.addEventListener("click", () => {
    const expanded = hamburger.getAttribute("aria-expanded") === "true";
    hamburger.setAttribute("aria-expanded", String(!expanded));
    navShell?.classList.toggle("open");
  });

  navItems.forEach((link) => {
    link.addEventListener("click", (event) => {
      if (window.innerWidth > 1024) return;
      const parent = link.parentElement;
      const isOpen = parent?.classList.contains("open");
      const href = link.getAttribute("href");

      if (!isOpen || href === "#") {
        event.preventDefault();
        parent?.classList.toggle("open");
      }
    });
  });
</script>
